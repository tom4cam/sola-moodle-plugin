      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_type_active" UNIQUE="false" FIELDS="courseid, type, active"/>
