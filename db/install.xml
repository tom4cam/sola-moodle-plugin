    <TABLE NAME="local_ai_course_assistant_course_cfg" COMMENT="Per-course AI provider configuration overrides">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="1 = use course overrides, 0 = use global config"/>
        <FIELD NAME="provider" TYPE="char" LENGTH="20" NOTNULL="false" SEQUENCE="false" COMMENT="AI provider override (blank = inherit global)"/>
        <FIELD NAME="apikey" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="API key override (blank = inherit global)"/>
        <FIELD NAME="model" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false" COMMENT="Model name override (blank = inherit global)"/>
        <FIELD NAME="apibaseurl" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="API base URL override (blank = inherit global)"/>
        <FIELD NAME="systemprompt" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="System prompt override (blank = inherit global)"/>
