(function() {
    var providerSelect = document.getElementById('ai-analysis-provider');
    var modelSelect = document.getElementById('ai-analysis-model');
    var messagesDiv = document.getElementById('ai-analysis-messages');
    var inputField = document.getElementById('ai-analysis-input');
    var sendBtn = document.getElementById('ai-analysis-send');
    var downloadBtn = document.getElementById('ai-analysis-download');
    var sseUrl = document.getElementById('ai-analysis-sse-url');
    var sesskey = document.getElementById('ai-analysis-sesskey');
    var courseidEl = document.getElementById('ai-analysis-courseid');
    var rangeEl = document.getElementById('ai-analysis-range');
    var scopeSelect = document.getElementById('ai-analysis-scope');
    var scopeDetail = document.getElementById('ai-analysis-scope-detail');
    var scopeValue = document.getElementById('ai-analysis-scope-value');

    if (!providerSelect || !modelSelect || !messagesDiv || !inputField || !sendBtn) return;

    var chatHistory = [];
    var lastResponse = '';

    // Scope selector: show/hide detail input.
    if (scopeSelect) {
        scopeSelect.addEventListener('change', function() {
            var v = scopeSelect.value;
            if (v === 'custom' || v === 'byprovider') {
                scopeDetail.style.display = '';
                scopeValue.placeholder = v === 'custom' ? 'Course IDs (e.g. 2,5,12)' : 'Provider (e.g. openai, claude)';
            } else {
                scopeDetail.style.display = 'none';
            }
        });
    }

    // CSV download of last response.
    if (downloadBtn) {
        downloadBtn.addEventListener('click', function() {
            if (!lastResponse) { alert('No response to download yet.'); return; }
            var csv = 'Field,Value\nQuery,"' + (inputField.value || '').replace(/"/g, '""') + '"\nResponse,"' + lastResponse.replace(/"/g, '""') + '"\nDate,"' + new Date().toISOString() + '"\nNote,"All student data is anonymized."\n';
            var blob = new Blob([csv], {type: 'text/csv'});
            var a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'sola_ai_analysis_' + Date.now() + '.csv';
            a.click();
        });
    }

    function populateModels() {
        var opt = providerSelect.options[providerSelect.selectedIndex];
        var models = [];
        try { models = JSON.parse(opt.getAttribute('data-models') || '[]'); } catch (e) {}
        modelSelect.innerHTML = '';
        if (!models.length) {
            var o = document.createElement('option');
            o.value = '';
            o.textContent = '(provider default)';
            modelSelect.appendChild(o);
        }
        for (var i = 0; i < models.length; i++) {
            var o = document.createElement('option');
            o.value = models[i];
            o.textContent = models[i];
            modelSelect.appendChild(o);
        }
    }
    providerSelect.addEventListener('change', populateModels);
    populateModels();

    function appendMessage(role, text) {
        var div = document.createElement('div');
        div.style.cssText = 'margin-bottom:10px;padding:8px 12px;border-radius:8px;max-width:90%;font-size:14px;line-height:1.5;white-space:pre-wrap;word-break:break-word;';
        if (role === 'user') {
            div.style.cssText += 'background:#023e8a;color:#fff;margin-left:auto;text-align:right;';
        } else {
            div.style.cssText += 'background:#fff;border:1px solid #dee2e6;';
        }
        div.textContent = text;
        // Clear the placeholder if it exists
        var placeholder = messagesDiv.querySelector('.text-muted');
        if (placeholder) placeholder.remove();
        messagesDiv.appendChild(div);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
        return div;
    }

    function sendQuery() {
        var query = inputField.value.trim();
        if (!query) return;

        appendMessage('user', query);
        chatHistory.push({ role: 'user', content: query });
        inputField.value = '';
        sendBtn.disabled = true;
        inputField.disabled = true;

        var responseDiv = appendMessage('assistant', '');
        var fullText = '';

        var params = new URLSearchParams();
        params.append('sesskey', sesskey ? sesskey.value : '');
        params.append('query', query);
        params.append('provider', providerSelect.value);
        params.append('model', modelSelect.value);
        params.append('range', rangeEl ? rangeEl.value : '30');
        params.append('history', JSON.stringify(chatHistory.slice(0, -1)));

        // Scope filters.
        var scope = scopeSelect ? scopeSelect.value : 'all';
        if (scope === 'current') {
            params.append('courseid', courseidEl ? courseidEl.value : '0');
        } else if (scope === 'custom') {
            params.append('courseids', scopeValue ? scopeValue.value : '');
        } else if (scope === 'byprovider') {
            params.append('filterprovider', scopeValue ? scopeValue.value : '');
        }
        // scope === 'all' sends no filter (all courses).

        var url = sseUrl ? sseUrl.value : '';
        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params.toString()
        }).then(function(resp) {
            var reader = resp.body.getReader();
            var decoder = new TextDecoder();
            var buffer = '';
            function read() {
                return reader.read().then(function(result) {
                    if (result.done) {
                        // Strip [SOLA_NEXT]...[/SOLA_NEXT] block from the visible
                        // response and render the 4 pipe-delimited suggestions
                        // as clickable chips that repopulate the query input.
                        var nextMatch = fullText.match(/\[SOLA_NEXT\]([\s\S]*?)\[\/SOLA_NEXT\]/);
                        var suggestions = [];
                        if (nextMatch) {
                            fullText = fullText.replace(nextMatch[0], '').trim();
                            responseDiv.textContent = fullText;
                            suggestions = nextMatch[1].split('||').map(function(s) { return s.trim(); }).filter(Boolean);
                        }
                        if (suggestions.length > 0) {
                            var chipRow = document.createElement('div');
                            chipRow.style.cssText = 'display:flex;flex-wrap:wrap;gap:6px;margin:8px 0 4px;';
                            suggestions.forEach(function(txt) {
                                var chip = document.createElement('button');
                                chip.type = 'button';
                                chip.textContent = txt;
                                chip.className = 'btn btn-sm btn-outline-primary';
                                chip.style.cssText = 'font-size:12px;padding:4px 10px;border-radius:14px;white-space:normal;text-align:left;';
                                chip.addEventListener('click', function() {
                                    inputField.value = txt;
                                    sendQuery();
                                });
                                chipRow.appendChild(chip);
                            });
                            messagesDiv.appendChild(chipRow);
                            messagesDiv.scrollTop = messagesDiv.scrollHeight;
                        }
                        chatHistory.push({ role: 'assistant', content: fullText });
                        lastResponse = fullText;
                        sendBtn.disabled = false;
                        inputField.disabled = false;
                        inputField.focus();
                        return;
                    }
                    buffer += decoder.decode(result.value, { stream: true });
                    var lines = buffer.split('\n');
                    buffer = lines.pop();
                    for (var i = 0; i < lines.length; i++) {
                        var line = lines[i].trim();
                        if (line.indexOf('data: ') === 0) {
                            try {
                                var payload = JSON.parse(line.substring(6));
                                if (payload.token) {
                                    fullText += payload.token;
                                    responseDiv.textContent = fullText;
                                    messagesDiv.scrollTop = messagesDiv.scrollHeight;
                                }
                                if (payload.message) {
                                    responseDiv.textContent = 'Error: ' + payload.message;
                                }
                                if (payload.full && !fullText) {
                                    fullText = payload.full;
                                    responseDiv.textContent = fullText;
                                }
                            } catch (e) {}
                        }
                    }
                    return read();
                });
            }
            return read();
        }).catch(function(err) {
            responseDiv.textContent = 'Error: ' + (err.message || 'Network error');
            sendBtn.disabled = false;
            inputField.disabled = false;
        });
    }

    sendBtn.addEventListener('click', sendQuery);
    inputField.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendQuery();
        }
    });

    // Metric chips: clicking a chip at the top of the Learning Radar opens the
    // chat card (if collapsed), fills the query, and sends. v3.9.8+.
    var chipButtons = document.querySelectorAll('.learning-radar-chip');
    chipButtons.forEach(function(chip) {
        chip.addEventListener('click', function() {
            var q = chip.getAttribute('data-query') || '';
            if (!q) return;
            var body = document.getElementById('ai-analysis-body');
            if (body && !body.classList.contains('show')) {
                var toggle = document.querySelector('[data-target="#ai-analysis-body"]');
                if (toggle) { toggle.click(); }
            }
            inputField.value = q;
            setTimeout(function() { sendQuery(); }, 150);
        });
    });
})();
