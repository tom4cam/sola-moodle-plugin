{{!
    @template local_ai_course_assistant/analytics_dashboard

    SOLA Analytics — admin-only dashboard with cross-course summary,
    per-course enable/disable toggles, and per-course drill-down.
}}
<div class="local-ai-tutor-analytics">

    {{! Navigation }}
    <div class="mb-3 d-flex flex-wrap gap-2" style="gap:8px">
        <a href="{{settings_url}}" class="btn btn-sm btn-outline-secondary">&larr; Plugin Settings</a>
        <a href="{{token_analytics_url}}" class="btn btn-sm btn-outline-secondary">&#36; Token Usage &amp; Cost</a>
    </div>

    {{! ═══ Cross-Course Summary ═══ }}
    <h3>SOLA Overview</h3>
    <div class="card-deck mb-4">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Courses with SOLA</h5>
                <p class="display-4">{{enabled_courses}}<small style="font-size:0.4em"> / {{total_courses}}</small></p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Active Courses</h5>
                <p class="display-4">{{active_courses}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Total Messages</h5>
                <p class="display-4">{{total_messages_all}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Active Students</h5>
                <p class="display-4">{{active_students_all}}</p>
            </div>
        </div>
    </div>

    {{! ═══ Course List with Enable/Disable Toggles ═══ }}
    <h3>Courses</h3>
    <p class="text-muted">Enable or disable SOLA per course. Click a course name to view detailed analytics.</p>

    {{#has_courses}}
    <div class="card mb-4">
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th class="text-center" style="width:120px">SOLA Status</th>
                        <th class="text-center" style="width:100px">Has Data</th>
                    </tr>
                </thead>
                <tbody>
                    {{#courses}}
                    <tr>
                        <td>
                            {{#has_data}}
                            <a href="{{form_action}}?courseid={{id}}&amp;range={{range}}">
                                <strong>{{fullname}}</strong>
                            </a>
                            {{/has_data}}
                            {{^has_data}}
                            {{fullname}}
                            {{/has_data}}
                            <small class="text-muted ml-1">({{shortname}})</small>
                        </td>
                        <td class="text-center">
                            <form method="post" action="{{form_action}}" style="display:inline">
                                <input type="hidden" name="sesskey" value="{{sesskey}}">
                                <input type="hidden" name="action" value="toggle">
                                <input type="hidden" name="togglecourseid" value="{{id}}">
                                <input type="hidden" name="courseid" value="{{courseid_param}}">
                                <input type="hidden" name="range" value="{{range}}">
                                {{#enabled}}
                                <input type="hidden" name="enabled" value="0">
                                <button type="submit" class="btn btn-sm btn-success" title="Click to disable">
                                    Enabled
                                </button>
                                {{/enabled}}
                                {{^enabled}}
                                <input type="hidden" name="enabled" value="1">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Click to enable">
                                    Disabled
                                </button>
                                {{/enabled}}
                            </form>
                        </td>
                        <td class="text-center">
                            {{#has_data}}<span class="badge badge-info">Yes</span>{{/has_data}}
                            {{^has_data}}<span class="text-muted">&mdash;</span>{{/has_data}}
                        </td>
                    </tr>
                    {{/courses}}
                </tbody>
            </table>
        </div>
    </div>
    {{/has_courses}}

    {{! ═══ Per-Course Analytics (if selected) ═══ }}
    {{#has_course_selected}}
    <hr>
    <h2>{{course.coursename}}</h2>

    {{! Time range selector }}
    <div class="mb-3">
        <span class="mr-2"><strong>Time Range:</strong></span>
        <div class="btn-group" role="group">
            <a href="{{url_7}}" class="btn btn-sm {{#range_7_selected}}btn-primary{{/range_7_selected}}{{^range_7_selected}}btn-outline-secondary{{/range_7_selected}}">
                Last 7 days
            </a>
            <a href="{{url_30}}" class="btn btn-sm {{#range_30_selected}}btn-primary{{/range_30_selected}}{{^range_30_selected}}btn-outline-secondary{{/range_30_selected}}">
                Last 30 days
            </a>
            <a href="{{url_all}}" class="btn btn-sm {{#range_all_selected}}btn-primary{{/range_all_selected}}{{^range_all_selected}}btn-outline-secondary{{/range_all_selected}}">
                All time
            </a>
        </div>
        <a href="{{course.token_analytics_url}}" class="btn btn-sm btn-outline-secondary ml-2">
            &#36; Token Usage &amp; Cost &rarr;
        </a>
    </div>

    {{^course.has_data}}
    <div class="alert alert-info">No SOLA usage data for this course yet.</div>
    {{/course.has_data}}

    {{#course.has_data}}

    {{! Overview cards }}
    <h3>Overview</h3>
    <div class="card-deck mb-4">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Conversations</h5>
                <p class="display-4">{{course.overview.total_conversations}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Messages</h5>
                <p class="display-4">{{course.overview.total_messages}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Active Students</h5>
                <p class="display-4">{{course.overview.active_students}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Avg Msgs/Student</h5>
                <p class="display-4">{{course.overview.avg_messages_per_student}}</p>
            </div>
        </div>
    </div>
    <div class="card-deck mb-4">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Off-topic Rate</h5>
                <p class="display-4">{{course.overview.offtopic_rate}}%</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Escalations</h5>
                <p class="display-4">{{course.overview.escalation_count}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Study Plans</h5>
                <p class="display-4">{{course.overview.studyplan_adoption}}</p>
            </div>
        </div>
    </div>

    {{! Usage trend chart }}
    <h3>Usage Trends</h3>
    <div class="card mb-4">
        <div class="card-body">
            <canvas id="aitc-usage-chart" height="80" data-daily-usage="{{course.daily_usage_json}}"></canvas>
        </div>
    </div>

    <div class="row">
        {{! Hotspots }}
        <div class="col-md-6">
            <h3>Hotspots</h3>
            <p class="text-muted">Course sections most frequently referenced in student messages.</p>
            {{#course.has_hotspots}}
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Section</th>
                        <th class="text-right">Mentions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#course.hotspots}}
                    <tr>
                        <td>{{section}}</td>
                        <td class="text-right"><span class="badge badge-warning">{{count}}</span></td>
                    </tr>
                    {{/course.hotspots}}
                </tbody>
            </table>
            {{/course.has_hotspots}}
            {{^course.has_hotspots}}
            <p class="text-muted">No hotspot data available yet.</p>
            {{/course.has_hotspots}}
        </div>

        {{! Common prompts }}
        <div class="col-md-6">
            <h3>Common Prompts</h3>
            <p class="text-muted">Recurring question patterns from students.</p>
            {{#course.has_common_prompts}}
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Pattern</th>
                        <th class="text-right">Frequency</th>
                    </tr>
                </thead>
                <tbody>
                    {{#course.common_prompts}}
                    <tr>
                        <td><code>{{pattern}}</code></td>
                        <td class="text-right"><span class="badge badge-info">{{frequency}}</span></td>
                    </tr>
                    {{/course.common_prompts}}
                </tbody>
            </table>
            {{/course.has_common_prompts}}
            {{^course.has_common_prompts}}
            <p class="text-muted">No recurring prompt patterns detected yet.</p>
            {{/course.has_common_prompts}}
        </div>
    </div>

    {{! Provider comparison }}
    {{#course.has_provider_comparison}}
    <h3 class="mt-4">Provider Comparison</h3>
    <div class="card mb-4">
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Provider</th>
                        <th class="text-right">Responses</th>
                        <th class="text-right">Avg Length</th>
                        <th class="text-right">Total Tokens</th>
                        <th class="text-right">Avg Tokens</th>
                    </tr>
                </thead>
                <tbody>
                    {{#course.provider_comparison}}
                    <tr>
                        <td><strong>{{provider}}</strong></td>
                        <td class="text-right"><span class="badge badge-primary">{{response_count}}</span></td>
                        <td class="text-right">{{avg_response_length}} chars</td>
                        <td class="text-right">{{total_tokens}}</td>
                        <td class="text-right">{{avg_tokens}}</td>
                    </tr>
                    {{/course.provider_comparison}}
                </tbody>
            </table>
        </div>
    </div>
    {{/course.has_provider_comparison}}

    {{! Student activity }}
    {{#course.has_students}}
    <h3 class="mt-4">Student Activity</h3>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Student</th>
                <th class="text-right">Messages</th>
                <th>Last Active</th>
            </tr>
        </thead>
        <tbody>
            {{#course.students}}
            <tr>
                <td>{{name}}</td>
                <td class="text-right">{{message_count}}</td>
                <td>{{last_active}}</td>
            </tr>
            {{/course.students}}
        </tbody>
    </table>
    {{/course.has_students}}

    {{! User feedback }}
    <h3 class="mt-4">User Feedback</h3>
    {{#course.has_feedback}}
    <div class="card-deck mb-4">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Total Responses</h5>
                <p class="display-4">{{course.feedback_total}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Average Rating</h5>
                <p class="display-4">{{course.feedback_avg}} <small style="font-size:0.4em">/ 5</small></p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Rating Distribution</h5>
                <div style="text-align:left;max-width:200px;margin:0 auto">
                    {{#course.feedback_ratings}}
                    <div style="display:flex;align-items:center;gap:6px;font-size:13px;margin-bottom:2px">
                        <span style="width:14px;text-align:right">{{stars}}</span>
                        <span style="color:#f59e0b">&#9733;</span>
                        <div style="flex:1;background:#f3f4f6;border-radius:4px;height:10px;overflow:hidden">
                            <div style="background:#f59e0b;height:100%;width:{{count}}px;min-width:{{#count}}2px{{/count}};max-width:100%"></div>
                        </div>
                        <span style="width:24px;text-align:right;color:#6c757d">{{count}}</span>
                    </div>
                    {{/course.feedback_ratings}}
                </div>
            </div>
        </div>
    </div>
    <div class="card mb-4">
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Rating</th>
                        <th>Comment</th>
                        <th>Browser / OS</th>
                        <th>Device</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    {{#course.feedback_entries}}
                    <tr>
                        <td>{{name}}</td>
                        <td style="color:#f59e0b;white-space:nowrap">{{{stars}}}</td>
                        <td>{{#has_comment}}{{comment}}{{/has_comment}}{{^has_comment}}<span class="text-muted">&mdash;</span>{{/has_comment}}</td>
                        <td><small>{{browser}}<br>{{os}}</small></td>
                        <td><small>{{device}} {{screen}}</small></td>
                        <td><small>{{date}}</small></td>
                    </tr>
                    {{/course.feedback_entries}}
                </tbody>
            </table>
        </div>
    </div>
    {{/course.has_feedback}}
    {{^course.has_feedback}}
    <p class="text-muted">No feedback received yet.</p>
    {{/course.has_feedback}}

    {{! Survey Results }}
    {{#course.has_survey_data}}
    <h3 class="mt-4">Survey Results</h3>
    <div class="alert alert-info">
        <strong>{{course.survey_data.total_responses}}</strong> survey response(s) collected.
    </div>

    {{#course.survey_data.questions}}
    <div class="card mb-3">
        <div class="card-header">
            <strong>{{text}}</strong>
            <span class="badge badge-secondary ml-2">{{response_count}} responses</span>
        </div>
        <div class="card-body">
            {{#is_multiple_choice}}
            <table class="table table-sm table-striped mb-0">
                <thead><tr><th>Option</th><th class="text-right" style="width:80px">Count</th></tr></thead>
                <tbody>
                    {{#options}}
                    <tr>
                        <td>{{label}}</td>
                        <td class="text-right"><span class="badge badge-primary">{{count}}</span></td>
                    </tr>
                    {{/options}}
                </tbody>
            </table>
            {{/is_multiple_choice}}

            {{#is_rating}}
            <div class="d-flex align-items-center mb-2">
                <span class="mr-2"><strong>Average:</strong></span>
                <span class="display-4" style="font-size:2rem;color:#f59e0b">{{average}}</span>
                <span class="ml-1 text-muted">/ 5</span>
            </div>
            <div style="max-width:300px">
                {{#distribution}}
                <div style="display:flex;align-items:center;gap:6px;font-size:13px;margin-bottom:2px">
                    <span style="width:14px;text-align:right">{{value}}</span>
                    <span style="color:#f59e0b">&#9733;</span>
                    <div style="flex:1;background:#f3f4f6;border-radius:4px;height:10px;overflow:hidden">
                        <div style="background:#f59e0b;height:100%;width:{{count}}0px;min-width:{{#count}}2px{{/count}};max-width:100%"></div>
                    </div>
                    <span style="width:24px;text-align:right;color:#6c757d">{{count}}</span>
                </div>
                {{/distribution}}
            </div>
            {{/is_rating}}

            {{#is_long_text}}
            {{#has_answers}}
            <ul class="list-group list-group-flush" style="max-height:300px;overflow-y:auto">
                {{#answers}}
                <li class="list-group-item" style="font-size:0.9em">{{text}}</li>
                {{/answers}}
            </ul>
            {{/has_answers}}
            {{^has_answers}}
            <p class="text-muted mb-0">No text responses yet.</p>
            {{/has_answers}}
            {{/is_long_text}}
        </div>
    </div>
    {{/course.survey_data.questions}}
    {{/course.has_survey_data}}
    {{^course.has_survey_data}}
    <h3 class="mt-4">Survey Results</h3>
    <p class="text-muted">No survey responses collected yet.</p>
    {{/course.has_survey_data}}

    {{! User Testing Results }}
    {{#course.has_usertesting_data}}
    <h3 class="mt-4">User Testing Results</h3>
    <div class="alert alert-info">
        <strong>{{course.usertesting_data.total_respondents}}</strong> tester(s) have submitted responses.
    </div>

    {{#course.usertesting_data.tasks}}
    <div class="card mb-3">
        <div class="card-header">
            <strong>{{instruction}}</strong>
            <span class="badge badge-secondary ml-2">{{response_count}} responses</span>
            <span class="badge badge-light ml-1" title="Average messages at time of response">Avg {{avg_messages}} msgs</span>
            <span class="badge badge-light ml-1" title="Average session duration at time of response">Avg {{avg_session_minutes}} min</span>
        </div>
        <div class="card-body">
            {{#is_action_then_rate}}
            <p><strong>Average Rating:</strong> {{avg_rating}} / 5</p>
            {{#has_comments}}
            <div style="max-height:200px;overflow-y:auto">
                {{#comments}}
                <div class="p-2 mb-1" style="background:#f8fafc;border-radius:6px;font-size:13px">{{text}}</div>
                {{/comments}}
            </div>
            {{/has_comments}}
            {{/is_action_then_rate}}

            {{#is_multiple_choice}}
            <table class="table table-sm">
                <thead><tr><th>Option</th><th>Count</th></tr></thead>
                <tbody>
                {{#options}}
                <tr><td>{{label}}</td><td>{{count}}</td></tr>
                {{/options}}
                </tbody>
            </table>
            {{/is_multiple_choice}}

            {{#is_free_response}}
            {{#has_answers}}
            <div style="max-height:200px;overflow-y:auto">
                {{#answers}}
                <div class="p-2 mb-1" style="background:#f8fafc;border-radius:6px;font-size:13px">{{text}}</div>
                {{/answers}}
            </div>
            {{/has_answers}}
            {{^has_answers}}
            <p class="text-muted">No responses yet.</p>
            {{/has_answers}}
            {{/is_free_response}}
        </div>
    </div>
    {{/course.usertesting_data.tasks}}
    {{/course.has_usertesting_data}}
    {{^course.has_usertesting_data}}
    <h3 class="mt-4">User Testing Results</h3>
    <p class="text-muted">No user testing responses collected yet.</p>
    {{/course.has_usertesting_data}}

    {{! AI Insights }}
    <h3 class="mt-4">AI Insights</h3>
    <p class="text-muted">Analyze feedback, survey, and user testing data to surface issues, feature requests, and recommendations.</p>
    {{#course.has_any_feedback_data}}
    <div class="card mb-4" id="ai-insights-card">
        <div class="card-body">
            <div id="ai-insights-content" style="display:none"></div>
            <div id="ai-insights-placeholder">
                <button type="button" class="btn btn-primary" id="btn-generate-insights"
                        data-courseid="{{course.courseid}}">
                    Generate AI Insights
                </button>
                <span id="ai-insights-spinner" class="ml-2" style="display:none">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                    Analyzing data&hellip; this may take a moment.
                </span>
            </div>
        </div>
    </div>
    {{/course.has_any_feedback_data}}
    {{^course.has_any_feedback_data}}
    <p class="text-muted">No feedback, survey, or user testing data to analyze yet.</p>
    {{/course.has_any_feedback_data}}

    {{/course.has_data}}
    {{/has_course_selected}}

    {{^has_course_selected}}
    <div class="alert alert-info mt-3">Select a course above to view detailed analytics.</div>
    {{/has_course_selected}}
</div>

{{#has_course_selected}}
{{#course.has_data}}
{{#js}}
(function() {
    var canvas = document.getElementById('aitc-usage-chart');
    if (!canvas) return;

    var data = JSON.parse(canvas.getAttribute('data-daily-usage') || '[]');
    if (!data.length) return;

    var ctx = canvas.getContext('2d');
    var width = canvas.offsetWidth;
    var height = canvas.offsetHeight || 200;
    canvas.width = width;
    canvas.height = height;

    var maxCount = Math.max(1, Math.max.apply(null, data.map(function(d) { return d.count; })));
    var barWidth = Math.max(2, (width - 60) / data.length - 1);
    var chartHeight = height - 40;
    var originX = 40;
    var originY = height - 25;

    ctx.strokeStyle = '#ddd';
    ctx.beginPath();
    ctx.moveTo(originX, 10);
    ctx.lineTo(originX, originY);
    ctx.lineTo(width - 10, originY);
    ctx.stroke();

    ctx.fillStyle = '#666';
    ctx.font = '11px sans-serif';
    ctx.textAlign = 'right';
    for (var i = 0; i <= 4; i++) {
        var val = Math.round(maxCount * i / 4);
        var y = originY - (chartHeight * i / 4);
        ctx.fillText(val, originX - 5, y + 4);
        ctx.strokeStyle = '#f0f0f0';
        ctx.beginPath();
        ctx.moveTo(originX, y);
        ctx.lineTo(width - 10, y);
        ctx.stroke();
    }

    ctx.fillStyle = '#4a6cf7';
    data.forEach(function(d, idx) {
        var barH = (d.count / maxCount) * chartHeight;
        var x = originX + 5 + idx * (barWidth + 1);
        ctx.fillRect(x, originY - barH, barWidth, barH);
    });

    ctx.fillStyle = '#666';
    ctx.textAlign = 'center';
    ctx.font = '10px sans-serif';
    var labelInterval = Math.max(1, Math.floor(data.length / 7));
    data.forEach(function(d, idx) {
        if (idx % labelInterval === 0 || idx === data.length - 1) {
            var x = originX + 5 + idx * (barWidth + 1) + barWidth / 2;
            var label = d.date.substring(5);
            ctx.fillText(label, x, originY + 15);
        }
    });
})();

    // AI Insights button handler.
    var insightsBtn = document.getElementById('btn-generate-insights');
    if (insightsBtn) {
        insightsBtn.addEventListener('click', function() {
            var courseid = parseInt(insightsBtn.getAttribute('data-courseid'), 10);
            var spinner = document.getElementById('ai-insights-spinner');
            var content = document.getElementById('ai-insights-content');
            var placeholder = document.getElementById('ai-insights-placeholder');

            insightsBtn.disabled = true;
            spinner.style.display = 'inline';

            require(['core/ajax'], function(Ajax) {
                Ajax.call([{
                    methodname: 'local_ai_course_assistant_generate_insights',
                    args: { courseid: courseid }
                }])[0].done(function(result) {
                    // Simple Markdown → HTML conversion for headings, bold, lists.
                    var html = result.insights
                        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                        .replace(/^#### (.+)$/gm, '<h6>$1</h6>')
                        .replace(/^### (.+)$/gm, '<h5>$1</h5>')
                        .replace(/^## (.+)$/gm, '<h4>$1</h4>')
                        .replace(/^# (.+)$/gm, '<h3>$1</h3>')
                        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
                        .replace(/^- (.+)$/gm, '<li>$1</li>')
                        .replace(/^(\d+)\. (.+)$/gm, '<li>$2</li>')
                        .replace(/(<li>.*<\/li>)/gs, '<ul>$1</ul>')
                        .replace(/<\/ul>\s*<ul>/g, '')
                        .replace(/\n{2,}/g, '<br><br>')
                        .replace(/\n/g, '<br>');

                    content.innerHTML = html;
                    content.style.display = 'block';
                    placeholder.style.display = 'none';

                    if (!result.success) {
                        content.innerHTML = '<div class="alert alert-danger">' + html + '</div>';
                    }
                }).fail(function(err) {
                    content.innerHTML = '<div class="alert alert-danger">Failed to generate insights: '
                        + (err.message || 'Unknown error') + '</div>';
                    content.style.display = 'block';
                    spinner.style.display = 'none';
                    insightsBtn.disabled = false;
                });
            });
        });
    }
{{/js}}
