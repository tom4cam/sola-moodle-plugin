{{!
    @template local_ai_course_assistant/analytics_dashboard

    SOLA Analytics — admin-only dashboard with cross-course summary,
    per-course enable/disable toggles, and per-course drill-down.

    Example context (json):
    {
        "settings_url": "#",
        "token_analytics_url": "#",
        "analytics_base_url": "#",
        "form_action": "https://example.invalid/local/ai_course_assistant/analytics.php",
        "meta_ai_sse_url": "https://example.invalid/local/ai_course_assistant/meta_ai_sse.php",
        "sesskey": "abc123",
        "courseid_param": 0,
        "range": 30,
        "enabled_courses": 12,
        "total_courses": 24,
        "active_courses": 9,
        "total_messages_all": 1420,
        "active_students_all": 318,
        "has_courses": false,
        "show_real_names": false,
        "student_mode": false,
        "has_meta_ai_providers": false
    }
}}
<div class="local-ai-tutor-analytics">

    {{! Navigation + Anonymization toggle }}
    <div class="mb-3 d-flex flex-wrap align-items-center" style="gap:8px">
        <a href="{{settings_url}}" class="btn btn-sm btn-outline-secondary">&larr; Plugin Settings</a>
        <a href="{{token_analytics_url}}" class="btn btn-sm btn-outline-secondary">&#36; Token Usage &amp; Cost</a>
        <a href="{{export_csv_url}}" class="btn btn-sm btn-outline-secondary" title="Download analytics as CSV">&#8615; Export CSV</a>
        <div style="margin-left:auto;display:flex;gap:8px">
            <form method="post" action="{{form_action}}" style="display:inline">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
                <input type="hidden" name="action" value="togglenames">
                <input type="hidden" name="courseid" value="{{courseid_param}}">
                <input type="hidden" name="range" value="{{range}}">
                <button type="submit" class="btn btn-sm {{#show_real_names}}btn-warning{{/show_real_names}}{{^show_real_names}}btn-outline-secondary{{/show_real_names}}">
                    {{#show_real_names}}&#128275; Hide Real Names{{/show_real_names}}{{^show_real_names}}&#128274; Show Real Names{{/show_real_names}}
                </button>
            </form>
            <form method="post" action="{{form_action}}" style="display:inline">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
                <input type="hidden" name="action" value="togglestudentmode">
                <input type="hidden" name="courseid" value="{{courseid_param}}">
                <input type="hidden" name="range" value="{{range}}">
                <button type="submit" class="btn btn-sm {{#student_mode}}btn-info{{/student_mode}}{{^student_mode}}btn-outline-secondary{{/student_mode}}">
                    {{#student_mode}}Exit Student Mode{{/student_mode}}{{^student_mode}}Student Mode{{/student_mode}}
                </button>
            </form>
        </div>
    </div>
    {{#show_real_names}}
    <div class="alert alert-warning py-2 mb-3" style="font-size:13px">
        <strong>Real names are visible.</strong> Student data is not anonymized in this session. Toggle off before sharing your screen or leaving this page.
    </div>
    {{/show_real_names}}
    {{#student_mode}}
    <div class="alert alert-info py-2 mb-3" style="font-size:13px">
        <strong>Student Mode active.</strong> The SOLA widget on course pages now shows exactly what students see. Exit here or press Ctrl+Shift+A from any page.
    </div>
    {{/student_mode}}

    {{! ═══ Header summary line ═══ }}
    <p class="text-muted small mb-3">
        {{enabled_courses}} of {{total_courses}} courses have AI Assistant enabled —
        <a href="{{courses_admin_url}}">manage course enrollment &rarr;</a>
    </p>

    {{! ═══ Learning Radar (always visible — no collapse) ═══ }}
    <div class="card mb-4 learning-radar" id="learning-radar"
         data-sse-url="{{meta_ai_sse_url}}"
         data-export-url="{{radar_export_url}}"
         data-schedule-url="{{radar_schedule_url}}"
         data-cite-url="{{radar_cite_url}}"
         data-redash-url="{{redash_pull_url}}"
         data-has-redash="{{#has_redash_key}}1{{/has_redash_key}}{{^has_redash_key}}0{{/has_redash_key}}"
         data-sesskey="{{sesskey}}"
         data-courseid="{{courseid_param}}"
         data-range="{{range}}"
         data-providers='{{{meta_ai_providers_json}}}'>
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap" style="gap:8px">
            <h4 class="mb-0">Learning Radar
                <small class="text-muted" style="font-size:13px">— ask questions about anonymized student data</small>
            </h4>
            <div style="display:flex;gap:6px;flex-wrap:wrap">
                <button type="button" class="btn btn-sm btn-outline-secondary" id="radar-share" title="Copy a link that pre-fills this query for another admin">
                    &#128279; Copy share link
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" id="radar-toggle-schedules"
                        data-bs-toggle="collapse" data-bs-target="#radar-schedules-body" aria-controls="radar-schedules-body" aria-expanded="false">
                    &#9881; Schedules (<span id="radar-schedule-count">{{radar_schedule_count}}</span>)
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" id="radar-toggle-history"
                        data-bs-toggle="collapse" data-bs-target="#radar-history-body" aria-controls="radar-history-body" aria-expanded="false">
                    &#128240; History
                </button>
            </div>
        </div>
        <div class="card-body">

            {{! Suggested starters (curated, always shown) }}
            <div class="text-muted small mb-1">Try a question:</div>
            <div class="learning-radar-starters" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px">
                {{#learning_radar_starters}}
                <button type="button" class="learning-radar-starter btn btn-sm btn-outline-primary"
                        data-query="{{query}}"
                        style="font-size:12px;padding:4px 10px;border-radius:14px">
                    {{label}}
                </button>
                {{/learning_radar_starters}}
            </div>

            {{! Live metric chips (data-derived, click-to-query) }}
            {{#learning_radar_chips.0}}
            <div class="text-muted small mb-1">Or click a metric to dig in:</div>
            <div class="learning-radar-chips" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px">
                {{#learning_radar_chips}}
                <button type="button"
                        class="learning-radar-chip btn btn-sm btn-outline-secondary"
                        data-query="{{query}}"
                        style="text-align:left;padding:8px 12px;background:#fff;border:1px solid #dee2e6;border-radius:6px;min-width:160px;cursor:pointer">
                    <div style="font-size:18px;font-weight:600;color:#212529;line-height:1.1">{{value}}</div>
                    <div style="font-size:11px;color:#6c757d;text-transform:uppercase;letter-spacing:0.3px;margin-top:2px">{{label}}</div>
                </button>
                {{/learning_radar_chips}}
            </div>
            {{/learning_radar_chips.0}}

            {{! Provider/model/scope/range row }}
            <div class="d-flex flex-wrap align-items-end mb-2" style="gap:8px">
                <div>
                    <label for="ai-analysis-provider" class="small text-muted mb-0">Provider</label>
                    <select id="ai-analysis-provider" class="form-control form-control-sm" style="width:180px"></select>
                </div>
                <div>
                    <label for="ai-analysis-model" class="small text-muted mb-0">Model</label>
                    <select id="ai-analysis-model" class="form-control form-control-sm" style="width:200px"></select>
                </div>
                <div>
                    <label for="ai-analysis-scope" class="small text-muted mb-0">Data scope</label>
                    <select id="ai-analysis-scope" class="form-control form-control-sm" style="width:200px">
                        <option value="all">All courses</option>
                        <option value="current" {{#courseid_param}}selected{{/courseid_param}}>Current course only</option>
                        <option value="custom">Specific course IDs...</option>
                        <option value="byprovider">By LLM provider used...</option>
                    </select>
                </div>
                <div id="ai-analysis-scope-detail" style="display:none">
                    <label for="ai-analysis-scope-value" class="small text-muted mb-0">Course IDs or provider</label>
                    <input type="text" id="ai-analysis-scope-value" class="form-control form-control-sm" style="width:200px" placeholder="e.g. 2,5,12 or openai">
                </div>
                <div>
                    <label for="ai-analysis-range-select" class="small text-muted mb-0">Range</label>
                    <select id="ai-analysis-range-select" class="form-control form-control-sm" style="width:140px">
                        <option value="1">Last 24 hours</option>
                        <option value="7">Last 7 days</option>
                        <option value="30" selected>Last 30 days</option>
                        <option value="90">Last 90 days</option>
                        <option value="0">All time</option>
                    </select>
                </div>
                <div class="form-check ml-2" style="margin-top:18px">
                    <input class="form-check-input" type="checkbox" id="ai-analysis-compare">
                    <label class="form-check-label small" for="ai-analysis-compare" title="Run the same query against a second provider/model">
                        Compare 2 models
                    </label>
                </div>
            </div>

            {{! Compare-mode second provider/model (shown only when toggle is on) }}
            <div class="d-flex flex-wrap align-items-end mb-2" style="gap:8px;display:none" id="ai-analysis-compare-row">
                <div>
                    <label for="ai-analysis-provider-b" class="small text-muted mb-0">Provider B</label>
                    <select id="ai-analysis-provider-b" class="form-control form-control-sm" style="width:180px"></select>
                </div>
                <div>
                    <label for="ai-analysis-model-b" class="small text-muted mb-0">Model B</label>
                    <select id="ai-analysis-model-b" class="form-control form-control-sm" style="width:200px"></select>
                </div>
                <div class="text-muted small" style="margin-left:auto">⚠ Compare runs 2 queries — cost will roughly double.</div>
            </div>

            {{! Two side-by-side message panes (right hidden when not comparing) }}
            <div id="ai-analysis-panes" style="display:flex;gap:8px;margin-bottom:12px">
                <div id="ai-analysis-messages" style="flex:1;max-height:420px;overflow-y:auto;border:1px solid #dee2e6;border-radius:6px;padding:12px;background:#f8f9fa;font-size:14px;min-width:0">
                    <p class="text-muted mb-0" style="font-size:13px">All data is anonymized. Pick a starter above, click a metric, or type a question.</p>
                </div>
                <div id="ai-analysis-messages-b" style="display:none;flex:1;max-height:420px;overflow-y:auto;border:1px solid #dee2e6;border-radius:6px;padding:12px;background:#f8f9fa;font-size:14px;min-width:0"></div>
            </div>

            <div class="input-group">
                <input type="text" id="ai-analysis-input" class="form-control"
                       placeholder="Ask about student data, trends, costs, feedback...">
                <div class="input-group-append" style="display:flex;flex-wrap:wrap;gap:0">
                    <button class="btn btn-primary" id="ai-analysis-send" type="button">Send</button>
                    <button class="btn btn-outline-secondary dropdown-toggle" id="radar-export-toggle" type="button"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        Export
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" id="radar-export-menu">
                        <li><h6 class="dropdown-header">Download</h6></li>
                        <li><a class="dropdown-item" data-export="json" href="#">JSON</a></li>
                        <li><a class="dropdown-item" data-export="csv" href="#">CSV</a></li>
                        <li><a class="dropdown-item" data-export="markdown" href="#">Markdown</a></li>
                        <li><a class="dropdown-item" data-export="pdf" href="#">PDF (print)</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><h6 class="dropdown-header">Send</h6></li>
                        <li><a class="dropdown-item" data-send="email" href="#">Email&hellip;</a></li>
                        <li><a class="dropdown-item" data-send="slack" href="#">Slack webhook&hellip;</a></li>
                        <li><a class="dropdown-item" data-send="teams" href="#">Teams webhook&hellip;</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><h6 class="dropdown-header">Redash</h6></li>
                        <li><a class="dropdown-item" data-redash href="#">Copy Redash pull URL</a></li>
                    </ul>
                    <button class="btn btn-outline-secondary" id="radar-schedule-this" type="button"
                            title="Save this query as a recurring scheduled report">
                        &#128338; Schedule&hellip;
                    </button>
                </div>
            </div>
            <div class="text-muted small mt-1" id="radar-cost-estimate" aria-live="polite"></div>
        </div>

        {{! Saved schedules — collapsed by default }}
        <div class="collapse border-top" id="radar-schedules-body">
            <div class="card-body" id="radar-schedules-pane">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Scheduled Queries</h5>
                    <button class="btn btn-sm btn-outline-primary" id="radar-new-schedule" type="button">+ New schedule</button>
                </div>
                {{#has_radar_schedules}}
                <table class="table table-sm" id="radar-schedule-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Frequency</th>
                            <th>Channels</th>
                            <th>Last run</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#radar_schedules}}
                        <tr data-id="{{id}}">
                            <td><strong>{{name}}</strong></td>
                            <td>{{frequency}}</td>
                            <td>
                                {{#recipient}}<span class="badge bg-secondary me-1" title="{{recipient}}">email</span>{{/recipient}}
                                {{#has_slack}}<span class="badge bg-secondary me-1">slack</span>{{/has_slack}}
                                {{#has_teams}}<span class="badge bg-secondary me-1">teams</span>{{/has_teams}}
                            </td>
                            <td>{{last_run}}</td>
                            <td>
                                {{#last_status_class}}<span class="badge bg-{{last_status_class}}-subtle">{{last_status}}</span>{{/last_status_class}}
                                {{^last_status}}—{{/last_status}}
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-secondary radar-sched-edit" data-id="{{id}}">Edit</button>
                                <button class="btn btn-sm btn-outline-{{#enabled}}warning{{/enabled}}{{^enabled}}success{{/enabled}} radar-sched-toggle"
                                        data-id="{{id}}" data-enabled="{{#enabled}}0{{/enabled}}{{^enabled}}1{{/enabled}}">
                                    {{#enabled}}Pause{{/enabled}}{{^enabled}}Enable{{/enabled}}
                                </button>
                                <button class="btn btn-sm btn-outline-danger radar-sched-delete" data-id="{{id}}">Delete</button>
                            </td>
                        </tr>
                        {{/radar_schedules}}
                    </tbody>
                </table>
                {{/has_radar_schedules}}
                {{^has_radar_schedules}}
                <p class="text-muted mb-0">No scheduled queries yet. Run a query above and click "Schedule" to set one up.</p>
                {{/has_radar_schedules}}
            </div>
        </div>

        {{! Past queries — collapsed by default, searchable }}
        <div class="collapse border-top" id="radar-history-body">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap" style="gap:8px">
                    <h5 class="mb-0">Past Queries</h5>
                    <input type="text" id="radar-history-search" class="form-control form-control-sm" style="max-width:280px"
                           placeholder="Search query text&hellip;" aria-label="Search past queries">
                </div>
                {{#has_radar_past}}
                <table class="table table-sm table-striped" id="radar-history-table">
                    <thead>
                        <tr>
                            <th>When</th>
                            <th>Query</th>
                            <th>Provider</th>
                            <th>Type</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#radar_past}}
                        <tr data-id="{{id}}" data-query="{{query}}">
                            <td><small class="text-muted">{{date}}</small></td>
                            <td><div style="max-width:480px">{{query}}</div></td>
                            <td><small>{{provider}}<br>{{model}}</small></td>
                            <td>
                                {{#scheduled}}<span class="badge bg-info-subtle">scheduled</span>{{/scheduled}}
                                {{^scheduled}}<span class="badge bg-secondary-subtle">ad-hoc</span>{{/scheduled}}
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-secondary radar-history-rerun" data-id="{{id}}">Re-run</button>
                            </td>
                        </tr>
                        {{/radar_past}}
                    </tbody>
                </table>
                {{/has_radar_past}}
                {{^has_radar_past}}
                <p class="text-muted mb-0">No queries run yet.</p>
                {{/has_radar_past}}
            </div>
        </div>
    </div>

    {{! Citation popover (created on first hover) is appended to body by JS. }}

    {{! ═══ Per-Course Analytics (if selected) ═══ }}
    {{#has_course_selected}}
    <hr>
    <div class="mb-2">
        <a href="{{analytics_base_url}}" class="btn btn-sm btn-outline-secondary">&larr; Back to All Courses</a>
    </div>
    <h2>{{course.coursename}}</h2>

    {{! Time range selector }}
    <div class="mb-3">
        <span class="mr-2"><strong>Time Range:</strong></span>
        <div class="btn-group" role="group">
            <a href="{{url_7}}" class="btn btn-sm {{#range_7_selected}}btn-primary{{/range_7_selected}}{{^range_7_selected}}btn-outline-secondary{{/range_7_selected}}">
                Last 7 days
            </a>
            <a href="{{url_30}}" class="btn btn-sm {{#range_30_selected}}btn-primary{{/range_30_selected}}{{^range_30_selected}}btn-outline-secondary{{/range_30_selected}}">
                Last 30 days
            </a>
            <a href="{{url_all}}" class="btn btn-sm {{#range_all_selected}}btn-primary{{/range_all_selected}}{{^range_all_selected}}btn-outline-secondary{{/range_all_selected}}">
                All time
            </a>
        </div>
        <a href="{{course.token_analytics_url}}" class="btn btn-sm btn-outline-secondary ml-2">
            &#36; Token Usage &amp; Cost &rarr;
        </a>
    </div>

    {{^course.has_data}}
    <div class="alert alert-info">No AI Assistant usage data for this course yet.</div>
    {{/course.has_data}}

    {{#course.has_data}}

    {{! Overview cards }}
    <h3>Overview</h3>
    <div class="card-deck mb-4">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Conversations</h5>
                <p class="display-4">{{course.overview.total_conversations}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Messages</h5>
                <p class="display-4">{{course.overview.total_messages}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Active Students</h5>
                <p class="display-4">{{course.overview.active_students}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Avg Msgs/Student</h5>
                <p class="display-4">{{course.overview.avg_messages_per_student}}</p>
            </div>
        </div>
    </div>
    <div class="card-deck mb-4">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Off-topic Rate</h5>
                <p class="display-4">{{course.overview.offtopic_rate}}%</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Escalations</h5>
                <p class="display-4">{{course.overview.escalation_count}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Study Plans</h5>
                <p class="display-4">{{course.overview.studyplan_adoption}}</p>
            </div>
        </div>
    </div>

    {{! Usage trend chart }}
    <h3>Usage Trends</h3>
    <div class="card mb-4">
        <div class="card-body">
            <canvas id="aitc-usage-chart" height="80" data-daily-usage="{{course.daily_usage_json}}"></canvas>
        </div>
    </div>

    <div class="row">
        {{! Hotspots }}
        <div class="col-md-6">
            <h3>Hotspots</h3>
            <p class="text-muted">Course sections most frequently referenced in student messages.</p>
            {{#course.has_hotspots}}
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Section</th>
                        <th class="text-right">Mentions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#course.hotspots}}
                    <tr>
                        <td>{{section}}</td>
                        <td class="text-right"><span class="badge badge-warning">{{count}}</span></td>
                    </tr>
                    {{/course.hotspots}}
                </tbody>
            </table>
            {{/course.has_hotspots}}
            {{^course.has_hotspots}}
            <p class="text-muted">No hotspot data available yet.</p>
            {{/course.has_hotspots}}
        </div>

        {{! Common prompts }}
        <div class="col-md-6">
            <h3>Common Prompts</h3>
            <p class="text-muted">Recurring question patterns from students.</p>
            {{#course.has_common_prompts}}
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Pattern</th>
                        <th class="text-right">Frequency</th>
                    </tr>
                </thead>
                <tbody>
                    {{#course.common_prompts}}
                    <tr>
                        <td><code>{{pattern}}</code></td>
                        <td class="text-right"><span class="badge badge-info">{{frequency}}</span></td>
                    </tr>
                    {{/course.common_prompts}}
                </tbody>
            </table>
            {{/course.has_common_prompts}}
            {{^course.has_common_prompts}}
            <p class="text-muted">No recurring prompt patterns detected yet.</p>
            {{/course.has_common_prompts}}
        </div>
    </div>

    {{! Provider comparison }}
    {{#course.has_provider_comparison}}
    <h3 class="mt-4">Provider Comparison</h3>
    <div class="card mb-4">
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Provider</th>
                        <th class="text-right">Responses</th>
                        <th class="text-right">Avg Length</th>
                        <th class="text-right">Total Tokens</th>
                        <th class="text-right">Avg Tokens</th>
                    </tr>
                </thead>
                <tbody>
                    {{#course.provider_comparison}}
                    <tr>
                        <td><strong>{{provider}}</strong></td>
                        <td class="text-right"><span class="badge badge-primary">{{response_count}}</span></td>
                        <td class="text-right">{{avg_response_length}} chars</td>
                        <td class="text-right">{{total_tokens}}</td>
                        <td class="text-right">{{avg_tokens}}</td>
                    </tr>
                    {{/course.provider_comparison}}
                </tbody>
            </table>
        </div>
    </div>
    {{/course.has_provider_comparison}}

    {{! Student activity }}
    {{#course.has_students}}
    <h3 class="mt-4">Student Activity</h3>
    <table class="table table-striped">
        <thead>
            <tr>
