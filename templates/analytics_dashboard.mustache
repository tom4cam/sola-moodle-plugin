(function() {
    // ── Course table: search, filter, sort, checkboxes, bulk actions ──
    var searchBox = document.getElementById('sola-course-search');
    var filterStatus = document.getElementById('sola-filter-status');
    var filterUt = document.getElementById('sola-filter-ut');
    var courseTable = document.getElementById('sola-course-table');
    var selectAll = document.getElementById('sola-select-all');
    var selectedCount = document.getElementById('sola-selected-count');
    var bulkForm = document.getElementById('sola-bulk-form');

    function getRows() {
        return courseTable ? Array.prototype.slice.call(courseTable.querySelectorAll('tbody tr')) : [];
    }

    function applyFilters() {
        var q = (searchBox ? searchBox.value : '').toLowerCase();
        var sf = filterStatus ? filterStatus.value : '';
        var uf = filterUt ? filterUt.value : '';
        var rows = getRows();
        for (var i = 0; i < rows.length; i++) {
            var r = rows[i];
            var matchText = !q || r.textContent.toLowerCase().indexOf(q) !== -1;
            var matchSola = !sf || r.getAttribute('data-sola') === sf;
            var matchUt = !uf || r.getAttribute('data-ut') === uf;
            r.style.display = (matchText && matchSola && matchUt) ? '' : 'none';
        }
        updateCount();
    }

    function updateCount() {
        if (!selectedCount) return;
        var checks = courseTable ? courseTable.querySelectorAll('.sola-row-check:checked') : [];
        selectedCount.textContent = '(' + checks.length + ' selected)';
    }

    function getSelectedIds() {
        var ids = [];
        if (!courseTable) return ids;
        var checks = courseTable.querySelectorAll('.sola-row-check:checked');
        for (var i = 0; i < checks.length; i++) {
            ids.push(checks[i].value);
        }
        return ids;
    }

    if (searchBox) searchBox.addEventListener('input', applyFilters);
    if (filterStatus) filterStatus.addEventListener('change', applyFilters);
    if (filterUt) filterUt.addEventListener('change', applyFilters);

    // Select all checkbox.
    if (selectAll && courseTable) {
        selectAll.addEventListener('change', function() {
            var checked = selectAll.checked;
            var rows = getRows();
            for (var i = 0; i < rows.length; i++) {
                if (rows[i].style.display !== 'none') {
                    var cb = rows[i].querySelector('.sola-row-check');
                    if (cb) cb.checked = checked;
                }
            }
            updateCount();
        });
    }

    // Individual checkbox updates.
    if (courseTable) {
        courseTable.addEventListener('change', function(e) {
            if (e.target.classList.contains('sola-row-check')) {
                updateCount();
                if (selectAll && !e.target.checked) selectAll.checked = false;
            }
        });
    }

    // Bulk action buttons.
    var bulkBtns = document.querySelectorAll('.sola-bulk-action');
    for (var b = 0; b < bulkBtns.length; b++) {
        bulkBtns[b].addEventListener('click', function() {
            var ids = getSelectedIds();
            var action = this.getAttribute('data-action');
            var label = action === 'bulktoggle' ? 'SOLA' : 'User Testing';

            if (ids.length === 0) {
                if (!confirm('No courses selected. Apply to ALL courses?')) return;
                document.getElementById('sola-bulk-form').querySelector('[name="scope"]').value = 'all';
            } else {
                if (!confirm('Apply ' + label + ' change to ' + ids.length + ' selected course(s)?')) return;
                document.getElementById('sola-bulk-form').querySelector('[name="scope"]').value = 'selected';
                document.getElementById('sola-bulk-form-ids').value = ids.join(',');
            }

            document.getElementById('sola-bulk-form-action').value = action;
            if (action === 'bulktoggle') {
                document.getElementById('sola-bulk-form-enabled').value = this.getAttribute('data-enabled');
            } else {
                document.getElementById('sola-bulk-form-utvalue').value = this.getAttribute('data-utvalue');
            }
            bulkForm.submit();
        });
    }

    // Sortable columns.
    var sortDir = {};
    var sortHeaders = courseTable ? courseTable.querySelectorAll('.sola-sortable') : [];
    for (var h = 0; h < sortHeaders.length; h++) {
        sortHeaders[h].addEventListener('click', function() {
            var col = this.getAttribute('data-sort');
            sortDir[col] = sortDir[col] === 'asc' ? 'desc' : 'asc';
            var dir = sortDir[col];
            var tbody = courseTable.querySelector('tbody');
            var rows = getRows();

            rows.sort(function(a, b) {
                var va, vb;
                if (col === 'name') {
                    va = a.cells[1].textContent.trim().toLowerCase();
                    vb = b.cells[1].textContent.trim().toLowerCase();
                } else if (col === 'sola') {
                    va = a.getAttribute('data-sola');
                    vb = b.getAttribute('data-sola');
                } else if (col === 'ut') {
                    va = a.getAttribute('data-ut');
                    vb = b.getAttribute('data-ut');
                } else if (col === 'data') {
                    va = a.getAttribute('data-hasdata');
                    vb = b.getAttribute('data-hasdata');
                }
                if (va < vb) return dir === 'asc' ? -1 : 1;
                if (va > vb) return dir === 'asc' ? 1 : -1;
                return 0;
            });

            for (var i = 0; i < rows.length; i++) {
                tbody.appendChild(rows[i]);
            }

            // Update sort icons.
            var icons = courseTable.querySelectorAll('.sola-sort-icon');
            for (var j = 0; j < icons.length; j++) {
                icons[j].innerHTML = '&#8597;';
            }
            this.querySelector('.sola-sort-icon').innerHTML = dir === 'asc' ? '&#9650;' : '&#9660;';
        });
    }
})();

