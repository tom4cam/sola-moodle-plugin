{{!
    @template local_ai_course_assistant/analytics_dashboard

    SOLA Analytics — admin-only dashboard with cross-course summary,
    per-course enable/disable toggles, and per-course drill-down.

    Example context (json):
    {
        "settings_url": "#",
        "token_analytics_url": "#",
        "analytics_base_url": "#",
        "form_action": "https://example.invalid/local/ai_course_assistant/analytics.php",
        "meta_ai_sse_url": "https://example.invalid/local/ai_course_assistant/meta_ai_sse.php",
        "sesskey": "abc123",
        "courseid_param": 0,
        "range": 30,
        "enabled_courses": 12,
        "total_courses": 24,
        "active_courses": 9,
        "total_messages_all": 1420,
        "active_students_all": 318,
        "has_courses": false,
        "show_real_names": false,
        "student_mode": false,
        "has_meta_ai_providers": false
    }
}}
<div class="local-ai-tutor-analytics">

    {{! Navigation + Anonymization toggle }}
    <div class="mb-3 d-flex flex-wrap align-items-center" style="gap:8px">
        <a href="{{settings_url}}" class="btn btn-sm btn-outline-secondary">&larr; Plugin Settings</a>
        <a href="{{token_analytics_url}}" class="btn btn-sm btn-outline-secondary">&#36; Token Usage &amp; Cost</a>
        <a href="{{export_csv_url}}" class="btn btn-sm btn-outline-secondary" title="Download analytics as CSV">&#8615; Export CSV</a>
        <div style="margin-left:auto;display:flex;gap:8px">
            <form method="post" action="{{form_action}}" style="display:inline">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
                <input type="hidden" name="action" value="togglenames">
                <input type="hidden" name="courseid" value="{{courseid_param}}">
                <input type="hidden" name="range" value="{{range}}">
                <button type="submit" class="btn btn-sm {{#show_real_names}}btn-warning{{/show_real_names}}{{^show_real_names}}btn-outline-secondary{{/show_real_names}}">
                    {{#show_real_names}}&#128275; Hide Real Names{{/show_real_names}}{{^show_real_names}}&#128274; Show Real Names{{/show_real_names}}
                </button>
            </form>
            <form method="post" action="{{form_action}}" style="display:inline">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
                <input type="hidden" name="action" value="togglestudentmode">
                <input type="hidden" name="courseid" value="{{courseid_param}}">
                <input type="hidden" name="range" value="{{range}}">
                <button type="submit" class="btn btn-sm {{#student_mode}}btn-info{{/student_mode}}{{^student_mode}}btn-outline-secondary{{/student_mode}}">
                    {{#student_mode}}Exit Student Mode{{/student_mode}}{{^student_mode}}Student Mode{{/student_mode}}
                </button>
            </form>
        </div>
    </div>
    {{#show_real_names}}
    <div class="alert alert-warning py-2 mb-3" style="font-size:13px">
        <strong>Real names are visible.</strong> Student data is not anonymized in this session. Toggle off before sharing your screen or leaving this page.
    </div>
    {{/show_real_names}}
    {{#student_mode}}
    <div class="alert alert-info py-2 mb-3" style="font-size:13px">
        <strong>Student Mode active.</strong> The SOLA widget on course pages now shows exactly what students see. Exit here or press Ctrl+Shift+A from any page.
    </div>
    {{/student_mode}}

    {{! ═══ Cross-Course Summary ═══ }}
    <h3>AI Course Assistant Overview</h3>
    <div class="card-deck mb-4">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Courses with AI Assistant</h5>
                <p class="display-4">{{enabled_courses}}<small style="font-size:0.4em"> / {{total_courses}}</small></p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Active Courses</h5>
                <p class="display-4">{{active_courses}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Total Messages</h5>
                <p class="display-4">{{total_messages_all}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Active Students</h5>
                <p class="display-4">{{active_students_all}}</p>
            </div>
        </div>
    </div>

    {{! ═══ Learning Radar ═══ }}
    {{#has_meta_ai_providers}}
    {{! Metric chips — at-a-glance numbers; click to submit a templated query to Learning Radar. v3.9.8+. }}
    {{#learning_radar_chips.0}}
    <div class="learning-radar-chips" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px">
        {{#learning_radar_chips}}
        <button type="button"
                class="learning-radar-chip btn btn-sm btn-outline-secondary"
                data-query="{{query}}"
                style="text-align:left;padding:8px 12px;background:#fff;border:1px solid #dee2e6;border-radius:6px;min-width:160px;cursor:pointer">
            <div style="font-size:20px;font-weight:600;color:#212529;line-height:1.1">{{value}}</div>
            <div style="font-size:11px;color:#6c757d;text-transform:uppercase;letter-spacing:0.3px;margin-top:2px">{{label}}</div>
        </button>
        {{/learning_radar_chips}}
    </div>
    {{/learning_radar_chips.0}}
    <div class="card mb-4" id="ai-analysis-chat-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Learning Radar <small class="text-muted" style="font-size:12px">(query anonymized student data)</small></h5>
            <button class="btn btn-sm btn-outline-secondary" type="button" data-toggle="collapse" data-target="#ai-analysis-body" aria-expanded="false" aria-controls="ai-analysis-body">Expand</button>
        </div>
        <div class="collapse" id="ai-analysis-body">
            <div class="card-body">
                <div class="d-flex flex-wrap align-items-end mb-2" style="gap:8px">
                    <div>
                        <label for="ai-analysis-provider" class="small text-muted mb-0">LLM to query with</label>
                        <select id="ai-analysis-provider" class="form-control form-control-sm" style="width:180px">
                            {{#meta_ai_providers}}
                            <option value="{{id}}" data-models="{{models_json}}">{{label}}</option>
                            {{/meta_ai_providers}}
                        </select>
                    </div>
                    <div>
                        <label for="ai-analysis-model" class="small text-muted mb-0">Model</label>
                        <select id="ai-analysis-model" class="form-control form-control-sm" style="width:200px"></select>
                    </div>
                    <div>
                        <label for="ai-analysis-scope" class="small text-muted mb-0">Data scope</label>
                        <select id="ai-analysis-scope" class="form-control form-control-sm" style="width:200px">
                            <option value="all">All courses</option>
                            <option value="current" {{#courseid_param}}selected{{/courseid_param}}>Current course only</option>
                            <option value="custom">Specific course IDs...</option>
                            <option value="byprovider">By LLM provider used...</option>
                        </select>
                    </div>
                    <div id="ai-analysis-scope-detail" style="display:none">
                        <label for="ai-analysis-scope-value" class="small text-muted mb-0">Course IDs or provider</label>
                        <input type="text" id="ai-analysis-scope-value" class="form-control form-control-sm" style="width:200px" placeholder="e.g. 2,5,12 or openai">
                    </div>
                </div>
                <div id="ai-analysis-messages" style="max-height:400px;overflow-y:auto;border:1px solid #dee2e6;border-radius:6px;padding:12px;margin-bottom:12px;background:#f8f9fa;font-size:14px">
                    <p class="text-muted mb-0" style="font-size:13px">Ask about student conversations, feedback, provider performance, token costs, or learning trends. All data is anonymized. Try: "Which provider gives the best student satisfaction?" or "What topics do students struggle with most?"</p>
                </div>
                <div class="input-group">
                    <input type="text" id="ai-analysis-input" class="form-control" placeholder="Ask about student data, trends, costs, feedback...">
                    <div class="input-group-append">
                        <button class="btn btn-primary" id="ai-analysis-send" type="button">Send</button>
                        <button class="btn btn-outline-secondary" id="ai-analysis-download" type="button" title="Download last response as CSV">&#8615; CSV</button>
                    </div>
                </div>
                <input type="hidden" id="ai-analysis-sse-url" value="{{meta_ai_sse_url}}">
                <input type="hidden" id="ai-analysis-sesskey" value="{{sesskey}}">
                <input type="hidden" id="ai-analysis-courseid" value="{{courseid_param}}">
                <input type="hidden" id="ai-analysis-range" value="{{range}}">
            </div>
        </div>
    </div>
    {{/has_meta_ai_providers}}

    {{! ═══ Course List with Enable/Disable Toggles ═══ }}
    <h3>Courses</h3>
    <p class="text-muted">Enable or disable AI Assistant per course. Click a course name to view detailed analytics.</p>

    {{#has_courses}}
    {{! Search + filter bar }}
    <div class="d-flex align-items-center mb-2 flex-wrap" style="gap:8px">
        <input type="text" id="sola-course-search" class="form-control form-control-sm" style="max-width:260px"
               placeholder="Search courses..." aria-label="Filter course list" autofocus>
        <select id="sola-filter-status" class="form-control form-control-sm" style="max-width:160px" aria-label="Filter by AI Assistant status">
            <option value="">All AI Assistant Status</option>
            <option value="enabled">AI Assistant Enabled</option>
            <option value="disabled">AI Assistant Disabled</option>
        </select>
        <select id="sola-filter-ut" class="form-control form-control-sm" style="max-width:180px" aria-label="Filter by user testing">
            <option value="">All Usability Testing</option>
            <option value="on">UT On</option>
            <option value="off">UT Off</option>
            <option value="inherit">UT Inherit</option>
        </select>
    </div>
    <p id="sola-default-limit-msg" class="text-muted mb-2" style="font-size:13px;display:none"></p>

    {{! Bulk action bar }}
    <div class="card mb-2 bg-light" id="sola-bulk-bar">
        <div class="card-body py-2 px-3 d-flex align-items-center flex-wrap" style="gap:8px">
            <label class="mb-0" style="font-weight:600;font-size:13px">
                <input type="checkbox" id="sola-select-all"> Select all
            </label>
            <span id="sola-selected-count" class="text-muted" style="font-size:13px">(0 selected)</span>
            <span class="mx-1" style="border-left:1px solid #ccc;height:20px"></span>

            <span style="font-size:13px;font-weight:600">AI Assistant:</span>
            <button type="button" class="btn btn-sm btn-outline-success sola-bulk-action" data-action="bulktoggle" data-enabled="1">
                Enable
            </button>
            <button type="button" class="btn btn-sm btn-outline-danger sola-bulk-action" data-action="bulktoggle" data-enabled="0">
                Disable
            </button>

            <span class="mx-1" style="border-left:1px solid #ccc;height:20px"></span>

            <span style="font-size:13px;font-weight:600">Usability Testing:</span>
            <button type="button" class="btn btn-sm btn-outline-success sola-bulk-action" data-action="bulktoggleut" data-utvalue="1">
                Enable
            </button>
            <button type="button" class="btn btn-sm btn-outline-danger sola-bulk-action" data-action="bulktoggleut" data-utvalue="0">
                Disable
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary sola-bulk-action" data-action="bulktoggleut" data-utvalue="">
                Inherit
            </button>
        </div>
    </div>

    {{! Hidden form for bulk submissions }}
    <form method="post" action="{{form_action}}" id="sola-bulk-form" style="display:none">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        <input type="hidden" name="action" id="sola-bulk-form-action" value="">
        <input type="hidden" name="courseid" value="{{courseid_param}}">
        <input type="hidden" name="range" value="{{range}}">
        <input type="hidden" name="scope" value="selected">
        <input type="hidden" name="selected_ids" id="sola-bulk-form-ids" value="">
        <input type="hidden" name="enabled" id="sola-bulk-form-enabled" value="">
        <input type="hidden" name="utvalue" id="sola-bulk-form-utvalue" value="">
    </form>

    <div class="card mb-4">
        <div class="card-body p-0">
            <table class="table table-striped mb-0" id="sola-course-table">
                <thead>
                    <tr>
                        <th style="width:40px" class="text-center"></th>
                        <th class="sola-sortable" data-sort="name" style="cursor:pointer">
                            Course <span class="sola-sort-icon">&#8597;</span>
                        </th>
                        <th class="text-center sola-sortable" data-sort="sola" style="width:120px;cursor:pointer">
                            AI Assistant <span class="sola-sort-icon">&#8597;</span>
                        </th>
                        <th class="text-center sola-sortable" data-sort="ut" style="width:140px;cursor:pointer">
                            Usability Testing <span class="sola-sort-icon">&#8597;</span>
                        </th>
                        <th class="text-center sola-sortable" data-sort="data" style="width:100px;cursor:pointer">
                            Has Data <span class="sola-sort-icon">&#8597;</span>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    {{#courses}}
                    <tr data-courseid="{{id}}"
                        data-sola="{{#enabled}}enabled{{/enabled}}{{^enabled}}disabled{{/enabled}}"
                        data-ut="{{#ut_on}}on{{/ut_on}}{{#ut_off}}off{{/ut_off}}{{#ut_inherit}}inherit{{/ut_inherit}}"
                        data-hasdata="{{#has_data}}1{{/has_data}}{{^has_data}}0{{/has_data}}">
                        <td class="text-center">
                            <input type="checkbox" class="sola-row-check" value="{{id}}">
                        </td>
                        <td>
                            {{#has_data}}
                            <a href="{{form_action}}?courseid={{id}}&amp;range={{range}}">
                                <strong>{{fullname}}</strong>
                            </a>
                            {{/has_data}}
                            {{^has_data}}
                            {{fullname}}
                            {{/has_data}}
                            <small class="text-muted ml-1">({{shortname}})</small>
                        </td>
                        <td class="text-center">
                            <form method="post" action="{{form_action}}" style="display:inline">
                                <input type="hidden" name="sesskey" value="{{sesskey}}">
                                <input type="hidden" name="action" value="toggle">
                                <input type="hidden" name="togglecourseid" value="{{id}}">
                                <input type="hidden" name="courseid" value="{{courseid_param}}">
                                <input type="hidden" name="range" value="{{range}}">
                                {{#enabled}}
                                <input type="hidden" name="enabled" value="0">
                                <button type="submit" class="btn btn-sm btn-success" title="Click to disable">
                                    Enabled
                                </button>
                                {{/enabled}}
                                {{^enabled}}
                                <input type="hidden" name="enabled" value="1">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Click to enable">
                                    Disabled
                                </button>
                                {{/enabled}}
                            </form>
                        </td>
                        <td class="text-center">
                            <form method="post" action="{{form_action}}" style="display:inline">
                                <input type="hidden" name="sesskey" value="{{sesskey}}">
                                <input type="hidden" name="action" value="toggleut">
                                <input type="hidden" name="togglecourseid" value="{{id}}">
                                <input type="hidden" name="courseid" value="{{courseid_param}}">
                                <input type="hidden" name="range" value="{{range}}">
                                {{#ut_on}}
                                <input type="hidden" name="utvalue" value="">
                                <button type="submit" class="btn btn-sm btn-success" title="On (per-course) — click to inherit global">
                                    On
                                </button>
                                {{/ut_on}}
                                {{#ut_off}}
                                <input type="hidden" name="utvalue" value="1">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Off (per-course) — click to enable">
                                    Off
                                </button>
                                {{/ut_off}}
                                {{#ut_inherit}}
                                <input type="hidden" name="utvalue" value="{{#ut_effective}}0{{/ut_effective}}{{^ut_effective}}1{{/ut_effective}}">
                                <button type="submit" class="btn btn-sm {{#ut_effective}}btn-outline-success{{/ut_effective}}{{^ut_effective}}btn-outline-secondary{{/ut_effective}}"
                                        title="Inheriting global ({{#ut_effective}}on{{/ut_effective}}{{^ut_effective}}off{{/ut_effective}}) — click to override">
                                    {{#ut_effective}}Global: On{{/ut_effective}}{{^ut_effective}}Global: Off{{/ut_effective}}
                                </button>
                                {{/ut_inherit}}
                            </form>
                        </td>
                        <td class="text-center">
                            {{#has_data}}<span class="badge badge-info">Yes</span>{{/has_data}}
                            {{^has_data}}<span class="text-muted">&mdash;</span>{{/has_data}}
                        </td>
                    </tr>
                    {{/courses}}
                </tbody>
            </table>
        </div>
    </div>
    {{/has_courses}}

    {{! ═══ Per-Course Analytics (if selected) ═══ }}
    {{#has_course_selected}}
    <hr>
    <div class="mb-2">
        <a href="{{analytics_base_url}}" class="btn btn-sm btn-outline-secondary">&larr; Back to All Courses</a>
    </div>
    <h2>{{course.coursename}}</h2>

    {{! Time range selector }}
    <div class="mb-3">
        <span class="mr-2"><strong>Time Range:</strong></span>
        <div class="btn-group" role="group">
            <a href="{{url_7}}" class="btn btn-sm {{#range_7_selected}}btn-primary{{/range_7_selected}}{{^range_7_selected}}btn-outline-secondary{{/range_7_selected}}">
                Last 7 days
            </a>
            <a href="{{url_30}}" class="btn btn-sm {{#range_30_selected}}btn-primary{{/range_30_selected}}{{^range_30_selected}}btn-outline-secondary{{/range_30_selected}}">
                Last 30 days
            </a>
            <a href="{{url_all}}" class="btn btn-sm {{#range_all_selected}}btn-primary{{/range_all_selected}}{{^range_all_selected}}btn-outline-secondary{{/range_all_selected}}">
                All time
            </a>
        </div>
        <a href="{{course.token_analytics_url}}" class="btn btn-sm btn-outline-secondary ml-2">
            &#36; Token Usage &amp; Cost &rarr;
        </a>
    </div>

    {{^course.has_data}}
    <div class="alert alert-info">No AI Assistant usage data for this course yet.</div>
    {{/course.has_data}}

    {{#course.has_data}}

    {{! Overview cards }}
    <h3>Overview</h3>
    <div class="card-deck mb-4">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Conversations</h5>
                <p class="display-4">{{course.overview.total_conversations}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Messages</h5>
                <p class="display-4">{{course.overview.total_messages}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Active Students</h5>
                <p class="display-4">{{course.overview.active_students}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Avg Msgs/Student</h5>
                <p class="display-4">{{course.overview.avg_messages_per_student}}</p>
            </div>
        </div>
    </div>
    <div class="card-deck mb-4">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Off-topic Rate</h5>
                <p class="display-4">{{course.overview.offtopic_rate}}%</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Escalations</h5>
                <p class="display-4">{{course.overview.escalation_count}}</p>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Study Plans</h5>
                <p class="display-4">{{course.overview.studyplan_adoption}}</p>
            </div>
        </div>
    </div>

    {{! Usage trend chart }}
    <h3>Usage Trends</h3>
    <div class="card mb-4">
        <div class="card-body">
            <canvas id="aitc-usage-chart" height="80" data-daily-usage="{{course.daily_usage_json}}"></canvas>
        </div>
    </div>

    <div class="row">
        {{! Hotspots }}
        <div class="col-md-6">
            <h3>Hotspots</h3>
            <p class="text-muted">Course sections most frequently referenced in student messages.</p>
            {{#course.has_hotspots}}
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Section</th>
                        <th class="text-right">Mentions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#course.hotspots}}
                    <tr>
                        <td>{{section}}</td>
                        <td class="text-right"><span class="badge badge-warning">{{count}}</span></td>
                    </tr>
                    {{/course.hotspots}}
                </tbody>
            </table>
            {{/course.has_hotspots}}
            {{^course.has_hotspots}}
            <p class="text-muted">No hotspot data available yet.</p>
            {{/course.has_hotspots}}
        </div>

        {{! Common prompts }}
        <div class="col-md-6">
            <h3>Common Prompts</h3>
            <p class="text-muted">Recurring question patterns from students.</p>
            {{#course.has_common_prompts}}
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Pattern</th>
                        <th class="text-right">Frequency</th>
                    </tr>
                </thead>
                <tbody>
                    {{#course.common_prompts}}
                    <tr>
                        <td><code>{{pattern}}</code></td>
                        <td class="text-right"><span class="badge badge-info">{{frequency}}</span></td>
                    </tr>
                    {{/course.common_prompts}}
                </tbody>
            </table>
            {{/course.has_common_prompts}}
            {{^course.has_common_prompts}}
            <p class="text-muted">No recurring prompt patterns detected yet.</p>
            {{/course.has_common_prompts}}
        </div>
    </div>

    {{! Provider comparison }}
    {{#course.has_provider_comparison}}
    <h3 class="mt-4">Provider Comparison</h3>
    <div class="card mb-4">
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Provider</th>
                        <th class="text-right">Responses</th>
                        <th class="text-right">Avg Length</th>
                        <th class="text-right">Total Tokens</th>
                        <th class="text-right">Avg Tokens</th>
                    </tr>
                </thead>
                <tbody>
                    {{#course.provider_comparison}}
                    <tr>
                        <td><strong>{{provider}}</strong></td>
                        <td class="text-right"><span class="badge badge-primary">{{response_count}}</span></td>
                        <td class="text-right">{{avg_response_length}} chars</td>
                        <td class="text-right">{{total_tokens}}</td>
                        <td class="text-right">{{avg_tokens}}</td>
                    </tr>
                    {{/course.provider_comparison}}
                </tbody>
            </table>
        </div>
    </div>
    {{/course.has_provider_comparison}}

    {{! Student activity }}
