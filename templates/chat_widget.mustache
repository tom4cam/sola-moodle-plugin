{{!
    @template local_ai_course_assistant/chat_widget

    Chat widget with floating avatar button and slide-in drawer.

    Context variables required for this template:
    * courseid - The course ID
    * sesskey - Session key for CSRF protection
    * avatarurl - URL to the avatar SVG
    * positionclass - CSS position class (bottom-right or bottom-left)
    * userrole - User role (student or teacher)
    * sseurl - URL for the SSE streaming endpoint

    Example context (json):
    {
        "courseid": 2,
        "userid": 5,
        "sesskey": "abc123",
        "avatarurl": "https://example.invalid/avatar.svg",
        "positionclass": "bottom-right",
        "startericoncolor": "#023e8a",
        "userrole": "student",
        "sseurl": "https://example.invalid/local/ai_course_assistant/sse.php",
        "availableavatars": "[\"default\"]",
        "quiztopics": "[]",
        "learningobjectives": "[]",
        "moduletitles": "[]",
        "offsetx": "24",
        "offsety": "24",
        "firstname": "Alex",
        "currentpageid": 17,
        "currentpagetitle": "Introduction",
        "modname": "page",
        "pagetype": "course-view",
        "realtimeenabled": "1",
        "ttsurl": "https://example.invalid/local/ai_course_assistant/tts.php",
        "avatarcolor": "#023e8a",
        "avatarfill": "#ffffff",
        "coursesettingsurl": "https://example.invalid/course/settings.php?id=2",
        "analyticsurl": "https://example.invalid/local/ai_course_assistant/analytics.php",
        "displaymode": "drawer",
        "displayname": "SOLA",
        "shortname_label": "SOLA",
        "institution": "Saylor Academy",
        "welcomemessage": "Welcome back.",
        "chatgreeting": "How can I help you today?",
        "coursename": "Test Course 101",
        "useremail": "alex@example.invalid",
        "userphone": "+15555550123",
        "surveyenabled": "1",
        "surveytrigger": "3",
        "completionpct": "42",
        "defaultvoice": "alloy",
        "contextlevelname": "module",
        "serverpageurl": "https://example.invalid/course/view.php?id=2",
        "serverpagetitle": "Introduction",
        "serverpageheading": "Introduction",
        "llmoptionsjson": "{}",
        "startersjson": "[{\"key\":\"help-page\",\"name\":\"Help with this page\"}]",
        "hasstarterdata": true,
        "starters": [
            {
                "key": "help-page",
                "type": "prompt",
                "prompt": "Help me understand this page.",
                "builtin": true,
                "description": "Review the current page.",
                "icon_svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" width=\"16\" height=\"16\" fill=\"currentColor\"><path d=\"M12 2 2 7l10 5 10-5-10-5Zm0 7L2 4v13l10 5 10-5V4l-10 5Z\"/></svg>",
                "name": "Help with this page"
            }
        ]
    }
}}
<div id="local-ai-course-assistant"
     class="local-ai-course-assistant local-ai-course-assistant--{{positionclass}}"
     style="--aica-starter-icon-color: {{startericoncolor}}{{^startericoncolor}}#023e8a{{/startericoncolor}};"
     data-courseid="{{courseid}}"
     data-userid="{{userid}}"
     data-sesskey="{{sesskey}}"
     data-userrole="{{userrole}}"
     data-sseurl="{{sseurl}}"
     data-avatarurl="{{avatarurl}}"
     data-availableavatars="{{availableavatars}}"
     data-quiz-topics="{{quiztopics}}"
     data-learning-objectives="{{learningobjectives}}"
     data-module-titles="{{moduletitles}}"
     data-offset-x="{{offsetx}}"
     data-offset-y="{{offsety}}"
     data-firstname="{{firstname}}"
     data-current-page-id="{{currentpageid}}"
     data-current-page-title="{{currentpagetitle}}"
     data-modname="{{modname}}"
     data-pagetype="{{pagetype}}"
     data-quiz-locked="{{#quizlocked}}1{{/quizlocked}}"
     data-realtimeenabled="{{realtimeenabled}}"
     data-ttsurl="{{ttsurl}}"
     data-avatar-color="{{avatarcolor}}"
     data-avatar-fill="{{avatarfill}}"
     data-settingsurl="{{coursesettingsurl}}"
     data-analyticsurl="{{analyticsurl}}"
     data-cansiteconfig="{{#cansiteconfig}}1{{/cansiteconfig}}"
     data-canviewanalytics="{{#canviewanalytics}}1{{/canviewanalytics}}"
     data-displaymode="{{displaymode}}"
     data-autoopen="{{#autoopen}}1{{/autoopen}}"
     data-displayname="{{displayname}}"
     data-shortname="{{shortname_label}}"
     data-institution="{{institution}}"
     data-practice-scoring="{{#practicescoring}}1{{/practicescoring}}"
     data-welcome-message="{{welcomemessage}}"
     data-chat-greeting="{{chatgreeting}}"
     data-coursename="{{coursename}}"
     data-intro-dismissed="{{#introdismissed}}1{{/introdismissed}}"
     data-emailreminders="{{#emailreminders}}1{{/emailreminders}}"
     data-whatsappreminders="{{#whatsappreminders}}1{{/whatsappreminders}}"
     data-useremail="{{useremail}}"
     data-userphone="{{userphone}}"
     data-surveyenabled="{{surveyenabled}}"
     data-surveytrigger="{{surveytrigger}}"
     data-completionpct="{{completionpct}}"
     data-defaultvoice="{{defaultvoice}}"
     data-context-debug="{{#contextdebugvisible}}1{{/contextdebugvisible}}"
     data-context-level="{{contextlevelname}}"
     data-server-page-url="{{serverpageurl}}"
     data-server-page-title="{{serverpagetitle}}"
     data-server-page-heading="{{serverpageheading}}"
     data-llm-options="{{llmoptionsjson}}"
     data-english-lock="{{#englishlock}}1{{/englishlock}}">

    {{! Floating avatar button }}
    <button id="local-ai-course-assistant-toggle"
            class="local-ai-course-assistant__toggle"
            type="button"
            aria-expanded="false"
            aria-controls="local-ai-course-assistant-drawer"
            title="{{#str}}chat:open, local_ai_course_assistant{{/str}}"
            aria-label="{{#str}}chat:open, local_ai_course_assistant{{/str}}">
        <span class="aica-avatar-svg aica-avatar-svg--toggle" aria-hidden="true"
              data-fallback-avatar="{{avatarurl}}">
            <img src="{{avatarurl}}" alt="" class="local-ai-course-assistant__avatar-img" aria-hidden="true" />
        </span>
    </button>

    {{! Chat drawer }}
    <div id="local-ai-course-assistant-drawer"
         class="local-ai-course-assistant__drawer"
         role="dialog"
         aria-label="{{shortname_label}}"
         aria-hidden="true"
         hidden>
        <button id="local-ai-course-assistant-close-toggle"
                class="local-ai-course-assistant__toggle local-ai-course-assistant__toggle--close"
                type="button"
                aria-expanded="false"
                aria-controls="local-ai-course-assistant-drawer"
                title="{{#str}}chat:close, local_ai_course_assistant{{/str}}"
                aria-label="{{#str}}chat:close, local_ai_course_assistant{{/str}}"
                hidden>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
            </svg>
        </button>

        {{! Swipe handle — mobile only; drag down to close }}
        <div class="aica-swipe-handle" aria-hidden="true"></div>

        {{! Header }}
        <div class="local-ai-course-assistant__header">
            <div class="local-ai-course-assistant__header-title">
                <button class="local-ai-course-assistant__btn-avatar"
                        title="{{#str}}chat:change_avatar, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:change_avatar, local_ai_course_assistant{{/str}}"
                        type="button">
                    <span class="aica-avatar-svg aica-avatar-svg--header" aria-hidden="true"
                          data-fallback-avatar="{{avatarurl}}">
                        <img src="{{avatarurl}}" alt="" class="local-ai-course-assistant__header-avatar" aria-hidden="true" />
                    </span>
                </button>
                <span>{{shortname_label}}</span>
            </div>
            <div class="local-ai-course-assistant__header-actions">
                {{#canviewanalytics}}
                <a href="{{analyticsurl}}"
                   class="local-ai-course-assistant__btn-analytics"
                   title="{{#str}}analytics:viewdashboard, local_ai_course_assistant{{/str}}"
                   aria-label="{{#str}}analytics:viewdashboard, local_ai_course_assistant{{/str}}"
                   target="_blank">
                    {{#pix}}i/stats, core, {{#str}}analytics:viewdashboard, local_ai_course_assistant{{/str}}{{/pix}}
                </a>
                {{/canviewanalytics}}
                {{#cansiteconfig}}
                <a href="{{coursesettingsurl}}"
                   class="local-ai-course-assistant__btn-settings"
                   title="{{#str}}chat:settings, local_ai_course_assistant{{/str}}"
                   aria-label="{{#str}}chat:settings, local_ai_course_assistant{{/str}}"
                   target="_blank">
                    {{! Wrench icon — admin/course settings }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>
                    </svg>
                </a>
                {{/cansiteconfig}}
                <button class="local-ai-course-assistant__btn-settings-panel"
                        title="{{#str}}chat:settings_panel, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:settings_panel, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{! Gear / settings icon }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16"
                         fill="currentColor" aria-hidden="true">
                        <path d="M19.14 12.94c.04-.3.06-.61.06-.94s-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.49.49 0 0 0-.59-.22l-2.39.96a7.02 7.02 0 0 0-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.48.48 0 0 0-.59.22L2.74 8.87a.47.47 0 0 0 .12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.37 1.04.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.57 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32a.47.47 0 0 0-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                    </svg>
                </button>
                {{#contextdebugvisible}}
                <button class="local-ai-course-assistant__btn-debug"
                        title="{{#str}}chat:debug_context_toggle, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:debug_context_toggle, local_ai_course_assistant{{/str}}"
                        aria-pressed="false"
                        type="button">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16"
                         fill="currentColor" aria-hidden="true">
                        <path d="M20 8h-2.81a5.985 5.985 0 0 0-1.82-1.96L17 4.41 15.59 3l-2.17 2.17C12.96 5.06 12.49 5 12 5s-.96.06-1.41.17L8.41 3 7 4.41l1.62 1.63C7.88 6.55 7.26 7.22 6.81 8H4v2h2.09c-.05.33-.09.66-.09 1v1H4v2h2v1c0 .34.04.67.09 1H4v2h2.81c1.04 1.79 2.97 3 5.19 3s4.15-1.21 5.19-3H20v-2h-2.09c.05-.33.09-.66.09-1v-1h2v-2h-2v-1c0-.34-.04-.67-.09-1H20V8zm-6 8h-4v-2h4v2zm0-4h-4v-2h4v2z"/>
                    </svg>
                </button>
                {{/contextdebugvisible}}
                <button class="local-ai-course-assistant__btn-clear"
                        title="{{#str}}chat:clear, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:clear, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{! Eraser icon — clear conversation history }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M15.14 3c-.51 0-1.02.2-1.41.59L2.59 14.73c-.78.77-.78 2.04 0 2.83l2.83 2.83c.39.39.9.59 1.41.59h4.24c.51 0 1.02-.2 1.41-.59l8.49-8.49c.78-.78.78-2.05 0-2.83l-4.24-4.24c-.39-.39-.9-.59-1.41-.59h.02zM6.83 19L4 16.17l5.93-5.93 2.83 2.83L6.83 19zM20 21H3v-2h17v2z"/>
                    </svg>
                </button>
                <button class="local-ai-course-assistant__btn-reset"
                        title="{{#str}}chat:reset, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:reset, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{! Home icon — return to conversation starters }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                    </svg>
                </button>
                <button class="local-ai-course-assistant__btn-close"
                        title="{{#str}}chat:close, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:close, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{! Close: standard X }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                    </svg>
                </button>
            </div>
        </div>

        {{! Focus sentinel — receives focus when drawer opens, prevents mobile keyboard pop-up }}
    <span class="aica-focus-sentinel" tabindex="-1" aria-hidden="true"></span>

    {{! Language banner — shown by JS when browser language is detected }}
        <div class="local-ai-course-assistant__lang-banner" aria-hidden="true">
            <span class="local-ai-course-assistant__lang-banner-text"></span>
            <div class="local-ai-course-assistant__lang-banner-actions">
                <button class="local-ai-course-assistant__lang-accept"
                        aria-label="{{#str}}chat:language_switch, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{#str}}lang:switch, local_ai_course_assistant{{/str}}
                </button>
                <button class="local-ai-course-assistant__lang-dismiss"
                        aria-label="{{#str}}chat:language_dismiss, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{#str}}lang:dismiss, local_ai_course_assistant{{/str}}
                </button>
            </div>
        </div>

        {{! Messages area }}
        <div class="local-ai-course-assistant__messages"
             role="log"
             aria-live="polite"
             aria-label="{{shortname_label}}">
        </div>

        {{#contextdebugvisible}}
        <div class="aica-debug-panel" hidden>
            <div class="aica-debug-panel__header">
                <span class="aica-debug-panel__title">{{#str}}chat:debug_context, local_ai_course_assistant{{/str}}</span>
                <button type="button"
                        class="aica-debug-panel__copy"
                        aria-label="{{#str}}chat:debug_context_copy, local_ai_course_assistant{{/str}}">
                    {{#str}}chat:debug_context_copy, local_ai_course_assistant{{/str}}
                </button>
            </div>
            <div class="aica-debug-panel__content">
                <div class="aica-debug-panel__section">
                    <div class="aica-debug-panel__label">{{#str}}chat:debug_context_browser, local_ai_course_assistant{{/str}}</div>
                    <pre class="aica-debug-panel__pre aica-debug-panel__pre--browser"></pre>
                </div>
                <div class="aica-debug-panel__section">
                    <div class="aica-debug-panel__label">{{#str}}chat:debug_context_request, local_ai_course_assistant{{/str}}</div>
                    <pre class="aica-debug-panel__pre aica-debug-panel__pre--request"></pre>
                </div>
                <div class="aica-debug-panel__section">
                    <div class="aica-debug-panel__label">{{#str}}chat:debug_context_prompt, local_ai_course_assistant{{/str}}</div>
                    <pre class="aica-debug-panel__pre aica-debug-panel__pre--prompt"></pre>
                </div>
            </div>
            <div class="aica-debug-panel__actions">
                <button type="button" class="aica-debug-panel__btn aica-debug-panel__refresh">{{#str}}chat:debug_refresh, local_ai_course_assistant{{/str}}</button>
                <button type="button" class="aica-debug-panel__btn aica-debug-panel__copy">{{#str}}chat:debug_copy_all, local_ai_course_assistant{{/str}}</button>
                <button type="button" class="aica-debug-panel__btn aica-debug-panel__btn--close aica-debug-panel__close">{{#str}}chat:debug_close, local_ai_course_assistant{{/str}}</button>
            </div>
        </div>
        {{/contextdebugvisible}}

        {{! Conversation starters — hidden once a message is sent }}
        <div class="local-ai-course-assistant__starters"
             role="group"
             aria-label="{{#str}}chat:starters_label, local_ai_course_assistant{{/str}}"
             data-starters="{{startersjson}}">
            {{#starters}}
            <button class="local-ai-course-assistant__starter"
                    type="button"
                    data-starter="{{key}}"
                    data-type="{{type}}"
                    data-prompt="{{prompt}}"
                    data-builtin="{{#builtin}}1{{/builtin}}"
                    {{#description}}title="{{description}}"{{/description}}>
                <span class="aica-starter-icon" aria-hidden="true">
                    {{{icon_svg}}}
                </span>
                <span>{{name}}</span>
            </button>
            {{/starters}}
            {{^hasstarterdata}}
            <button class="local-ai-course-assistant__starter" type="button" data-builtin="1" data-starter="help-page">
                <span class="aica-starter-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z"/></svg>
                </span>
                <span>{{#str}}chat:starter_help_page, local_ai_course_assistant{{/str}}</span>
            </button>
            <button class="local-ai-course-assistant__starter" type="button" data-builtin="1" data-starter="quiz">
                <span class="aica-starter-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M7 2v11h3v9l7-12h-4l4-8z"/></svg>
                </span>
                <span>{{#str}}chat:starter_quiz, local_ai_course_assistant{{/str}}</span>
            </button>
            <button class="local-ai-course-assistant__starter" type="button" data-builtin="1" data-starter="ask-anything">
                <span class="aica-starter-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>
                </span>
                <span>{{#str}}chat:starter_ask_anything, local_ai_course_assistant{{/str}}</span>
            </button>
            <button class="local-ai-course-assistant__starter" type="button" data-builtin="1" data-starter="review-practice">
                <span class="aica-starter-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46A7.93 7.93 0 0 0 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74A7.93 7.93 0 0 0 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"/></svg>
                </span>
                <span>{{#str}}chat:starter_review_practice, local_ai_course_assistant{{/str}}</span>
            </button>
            <button class="local-ai-course-assistant__starter" type="button" data-builtin="1" data-starter="study-plan">
                <span class="aica-starter-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M20 3h-1V1h-2v2H7V1H5v2H4C2.9 5 2 5.9 2 7v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 18H4V10h16v11zm0-13H4V7h16v1z"/></svg>
                </span>
                <span>{{#str}}chat:starter_study_plan, local_ai_course_assistant{{/str}}</span>
            </button>
            <button class="local-ai-course-assistant__starter" type="button" data-builtin="1" data-starter="ai-project-coach">
                <span class="aica-starter-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 2.5c0 0-5 4-5 11.5 0 2.5.5 4 1.5 5.5L10 21l2-3 2 3 1.5-1.5C16.5 18 17 16.5 17 14c0-7.5-5-11.5-5-11.5zm0 11a2 2 0 1 1 0-4 2 2 0 0 1 0 4zM5 17.5c-.3 1.5-.5 2.5-.5 4h3c0-1.5-.2-2.5-.5-4H5zm12 0c-.3 1.5-.5 2.5-.5 4h3c0-1.5-.2-2.5-.5-4h-2z"/></svg>
                </span>
                <span>{{#str}}chat:starter_ai_project_coach, local_ai_course_assistant{{/str}}</span>
            </button>
            {{#ttsurl}}
            <button class="local-ai-course-assistant__starter" type="button" data-builtin="1" data-starter="ell-practice">
                <span class="aica-starter-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.93V21h2v-3.07A7 7 0 0 0 19 11h-2z"/></svg>
                </span>
                <span>{{#str}}chat:starter_ell_practice, local_ai_course_assistant{{/str}}</span>
            </button>
            {{/ttsurl}}
            {{#ellpronunciationenabled}}
            <button class="local-ai-course-assistant__starter" type="button" data-builtin="1" data-starter="ell-pronunciation">
                <span class="aica-starter-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0 0 14 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
                </span>
                <span>{{#str}}chat:starter_ell_pronunciation, local_ai_course_assistant{{/str}}</span>
            </button>
            {{/ellpronunciationenabled}}
            {{/hasstarterdata}}
        </div>

        <div class="local-ai-course-assistant__voice-panel" hidden>
            <div class="aica-mode-card aica-mode-card--voice">
                <div class="aica-mode-card__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                        <path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.93V21h2v-3.07A7 7 0 0 0 19 11h-2z"/>
                    </svg>
                </div>
                <div class="aica-mode-card__body">
                    <div class="aica-mode-card__eyebrow">{{#str}}chat:mode_voice, local_ai_course_assistant{{/str}}</div>
                    <h3 class="aica-mode-card__title">{{#str}}chat:voice_panel_title, local_ai_course_assistant, {{shortname_label}}{{/str}}</h3>
                    <p class="aica-mode-card__text">{{#str}}chat:voice_copy, local_ai_course_assistant{{/str}}</p>
                    <p class="aica-mode-card__status">{{#str}}chat:voice_ready, local_ai_course_assistant{{/str}}</p>
                </div>
                <div class="aica-mode-card__actions">
                    <button type="button"
                            class="aica-mode-card__primary aica-voice-panel__start"
                            data-start-label="{{#str}}chat:voice_start, local_ai_course_assistant{{/str}}"
                            data-stop-label="{{#str}}chat:voice_end, local_ai_course_assistant{{/str}}">
                        {{#str}}chat:voice_start, local_ai_course_assistant{{/str}}
                    </button>
                </div>
            </div>
        </div>

        <div class="local-ai-course-assistant__history-panel"
             data-empty-label="{{#str}}chat:history_empty, local_ai_course_assistant{{/str}}"
             data-recent-subtitle="{{#str}}chat:history_subtitle, local_ai_course_assistant{{/str}}"
             data-saved-subtitle="{{#str}}chat:history_saved_subtitle, local_ai_course_assistant{{/str}}"
             data-saved-empty-label="{{#str}}chat:history_saved_empty, local_ai_course_assistant{{/str}}"
             data-you-label="{{#str}}chat:you, local_ai_course_assistant{{/str}}"
             data-assistant-label="{{displayname}}"
             hidden>
            <div class="aica-history-panel">
                <div class="aica-history-panel__header">
                    <div>
                        <div class="aica-history-panel__eyebrow">{{#str}}chat:mode_history, local_ai_course_assistant{{/str}}</div>
                        <h3 class="aica-history-panel__title">{{#str}}chat:history_title, local_ai_course_assistant{{/str}}</h3>
                    </div>
                    <button type="button" class="aica-history-panel__refresh">
                        {{#str}}chat:history_refresh, local_ai_course_assistant{{/str}}
                    </button>
                </div>
                <p class="aica-history-panel__subtitle">{{#str}}chat:history_subtitle, local_ai_course_assistant{{/str}}</p>
                <div class="aica-history-panel__views" role="tablist" aria-label="{{#str}}chat:history_views_label, local_ai_course_assistant{{/str}}">
                    <button type="button"
                            class="aica-history-panel__view aica-history-panel__view--active"
                            data-history-view="saved"
                            aria-pressed="true">
                        {{#str}}chat:history_view_saved, local_ai_course_assistant{{/str}}
                    </button>
                    <button type="button"
                            class="aica-history-panel__view"
                            data-history-view="recent"
                            aria-pressed="false">
                        {{#str}}chat:history_view_recent, local_ai_course_assistant{{/str}}
                    </button>
                </div>
                <div class="aica-history-panel__list" aria-live="polite"></div>
            </div>
        </div>

        {{! Stop button slot — always visible outside the scrollable messages area }}
        <div class="local-ai-course-assistant__stop-slot" hidden></div>

        {{! Typing indicator }}
        <div class="local-ai-course-assistant__typing" aria-hidden="true" role="status">
            <span class="local-ai-course-assistant__typing-dot"></span>
            <span class="local-ai-course-assistant__typing-dot"></span>
            <span class="local-ai-course-assistant__typing-dot"></span>
        </div>

        {{! Input area }}
        <div class="local-ai-course-assistant__input-area">
            <div class="local-ai-course-assistant__composer-card">
                <textarea class="local-ai-course-assistant__input"
                          placeholder="{{#str}}chat:placeholder, local_ai_course_assistant{{/str}}"
                          rows="1"
                          aria-label="{{#str}}chat:placeholder, local_ai_course_assistant{{/str}}"></textarea>
                <div class="local-ai-course-assistant__composer-bar">
                    <div class="local-ai-course-assistant__composer-left" hidden>
                        <label class="local-ai-course-assistant__composer-select-wrap" hidden>
                            <span class="local-ai-course-assistant__composer-select-label">{{#str}}chat:llm_label, local_ai_course_assistant{{/str}}</span>
                            <span class="local-ai-course-assistant__composer-select-shell">
                                <select class="local-ai-course-assistant__composer-select local-ai-course-assistant__composer-select--provider"
                                        aria-label="{{#str}}chat:llm_provider_select, local_ai_course_assistant{{/str}}"></select>
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" width="12" height="12" fill="currentColor" aria-hidden="true">
                                    <path d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06z"/>
                                </svg>
                            </span>
                        </label>
                        <label class="local-ai-course-assistant__composer-select-wrap" hidden>
                            <span class="local-ai-course-assistant__composer-select-label">{{#str}}chat:llm_model_label, local_ai_course_assistant{{/str}}</span>
                            <span class="local-ai-course-assistant__composer-select-shell">
                                <select class="local-ai-course-assistant__composer-select local-ai-course-assistant__composer-select--model"
                                        aria-label="{{#str}}chat:llm_model_select, local_ai_course_assistant{{/str}}"></select>
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" width="12" height="12" fill="currentColor" aria-hidden="true">
                                    <path d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06z"/>
                                </svg>
                            </span>
                        </label>
                    </div>
                    <div class="local-ai-course-assistant__composer-right">
                        <button class="local-ai-course-assistant__btn-mic"
                                title="{{#str}}chat:mic, local_ai_course_assistant{{/str}}"
                                aria-label="{{#str}}chat:mic, local_ai_course_assistant{{/str}}"
                                type="button">
                            <svg class="aica-icon-mic" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.93V21h2v-3.07A7 7 0 0 0 19 11h-2z"/>
                            </svg>
                            <svg class="aica-icon-mic-stop" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <path d="M19 11h-2a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.93V21h2v-3.07A7 7 0 0 0 19 11zM9 5a3 3 0 0 1 6 0v6a3 3 0 0 1-6 0V5z" opacity=".3"/>
                                <rect x="9" y="9" width="6" height="6" rx="1"/>
                            </svg>
                        </button>
                        <button class="local-ai-course-assistant__btn-send"
                                title="{{#str}}chat:send, local_ai_course_assistant{{/str}}"
                                aria-label="{{#str}}chat:send, local_ai_course_assistant{{/str}}"
                                type="button"
                                disabled>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
                                <path d="M12 18V6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M7.5 10.5L12 6l4.5 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
        {{! Resize handles — drag top/left edges to resize the drawer }}
        <div class="aica-resize-handle aica-resize-handle--n" aria-hidden="true"></div>
        <div class="aica-resize-handle aica-resize-handle--w" aria-hidden="true"></div>
        <div class="aica-resize-handle aica-resize-handle--nw" aria-hidden="true"></div>

        <div class="local-ai-course-assistant__footer-feedback"
             {{#usertestingenabled}}data-usertesting-enabled="1"{{/usertestingenabled}}
             data-usertesting-external-url="{{usertestingexternalurl}}">
            {{#usertestingenabled}}
            <button type="button" class="local-ai-course-assistant__footer-usertesting-link">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                {{#str}}chat:footer_usertesting, local_ai_course_assistant{{/str}}
            </button>
            <span style="color:#d1d5db;font-size:11px">|</span>
            {{/usertestingenabled}}
            <button type="button" class="local-ai-course-assistant__footer-feedback-link">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true">
                    <path d="M2 20h2c.55 0 1-.45 1-1v-9c0-.55-.45-1-1-1H2v11zm19.83-7.12c.11-.25.17-.52.17-.8V11c0-1.1-.9-2-2-2h-5.5l.92-4.65c.05-.22.02-.46-.08-.66a4.8 4.8 0 0 0-.88-1.22L14 2 7.59 8.41C7.21 8.79 7 9.3 7 9.83v7.84A2.34 2.34 0 0 0 9.34 20h8.11c.7 0 1.36-.37 1.72-.97l2.66-6.15z"/>
                </svg>
                {{#str}}chat:footer_feedback, local_ai_course_assistant{{/str}}
            </button>
        </div>

        <div class="local-ai-course-assistant__bottom-nav"
             role="group"
             aria-label="{{#str}}chat:mode_nav, local_ai_course_assistant{{/str}}">
            <button type="button"
                    class="local-ai-course-assistant__mode-btn local-ai-course-assistant__mode-btn--active"
                    data-mode="chat"
                    aria-pressed="true">
                <span class="local-ai-course-assistant__mode-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                        <path d="M4 4h10a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2H8l-4 3v-3H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/>
                        <path d="M18 8h2a2 2 0 0 1 2 2v8l-4-3h-4a2 2 0 0 1-2-2v-1h2a4 4 0 0 0 4-4z" opacity=".72"/>
                    </svg>
                </span>
                <span class="local-ai-course-assistant__mode-label">{{#str}}chat:mode_chat, local_ai_course_assistant{{/str}}</span>
            </button>
            {{#voicetabenabled}}
            <button type="button"
                    class="local-ai-course-assistant__mode-btn"
                    data-mode="voice"
                    aria-pressed="false">
                <span class="local-ai-course-assistant__mode-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                        <path d="M5.5 10a1 1 0 0 1 1 1v2a1 1 0 1 1-2 0v-2a1 1 0 0 1 1-1zm4-3a1 1 0 0 1 1 1v8a1 1 0 1 1-2 0V8a1 1 0 0 1 1-1zm5-2a1 1 0 0 1 1 1v12a1 1 0 1 1-2 0V6a1 1 0 0 1 1-1zm4 4a1 1 0 0 1 1 1v4a1 1 0 1 1-2 0v-4a1 1 0 0 1 1-1z"/>
                    </svg>
                </span>
                <span class="local-ai-course-assistant__mode-label">{{#str}}chat:mode_voice, local_ai_course_assistant{{/str}}</span>
            </button>
            {{/voicetabenabled}}
            <button type="button"
                    class="local-ai-course-assistant__mode-btn"
                    data-mode="history"
                    aria-pressed="false">
                <span class="local-ai-course-assistant__mode-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                        <path d="M17 3H7a2 2 0 0 0-2 2v16l7-4 7 4V5a2 2 0 0 0-2-2zm0 15-5-2.86L7 18V5h10v13z"/>
                    </svg>
                </span>
                <span class="local-ai-course-assistant__mode-label">{{#str}}chat:mode_history, local_ai_course_assistant{{/str}}</span>
            </button>
        </div>
    </div>
</div>
{{#use_cdn}}
<link rel="stylesheet" href="{{cdn_css_url}}" />
<script>window.SOLA_I18N = {{{i18n_json}}};</script>
<script src="{{cdn_js_url}}" defer></script>
{{/use_cdn}}
