{{!
    @template local_ai_course_assistant/chat_widget

    Chat widget with floating avatar button and slide-in drawer.

    Context variables required for this template:
    * courseid - The course ID
    * sesskey - Session key for CSRF protection
    * avatarurl - URL to the avatar SVG
    * positionclass - CSS position class (bottom-right or bottom-left)
    * userrole - User role (student or teacher)
    * sseurl - URL for the SSE streaming endpoint

    Example context (json):
    {
        "courseid": 2,
        "userid": 5,
        "sesskey": "abc123",
        "avatarurl": "https://example.invalid/avatar.svg",
        "positionclass": "bottom-right",
        "startericoncolor": "#023e8a",
        "userrole": "student",
        "sseurl": "https://example.invalid/local/ai_course_assistant/sse.php",
        "availableavatars": "[\"default\"]",
        "quiztopics": "[]",
        "learningobjectives": "[]",
        "moduletitles": "[]",
        "offsetx": "24",
        "offsety": "24",
        "firstname": "Alex",
        "currentpageid": 17,
        "currentpagetitle": "Introduction",
        "modname": "page",
        "pagetype": "course-view",
        "realtimeenabled": "1",
        "ttsurl": "https://example.invalid/local/ai_course_assistant/tts.php",
        "avatarcolor": "#023e8a",
        "avatarfill": "#ffffff",
        "coursesettingsurl": "https://example.invalid/course/settings.php?id=2",
        "analyticsurl": "https://example.invalid/local/ai_course_assistant/analytics.php",
        "displaymode": "drawer",
        "displayname": "SOLA",
        "shortname_label": "SOLA",
        "institution": "Saylor Academy",
        "welcomemessage": "Welcome back.",
        "chatgreeting": "How can I help you today?",
        "coursename": "Test Course 101",
        "useremail": "alex@example.invalid",
        "userphone": "+15555550123",
        "surveyenabled": "1",
        "surveytrigger": "3",
        "completionpct": "42",
        "defaultvoice": "alloy",
        "contextlevelname": "module",
        "serverpageurl": "https://example.invalid/course/view.php?id=2",
        "serverpagetitle": "Introduction",
        "serverpageheading": "Introduction",
        "llmoptionsjson": "{}",
        "startersjson": "[{\"key\":\"help-page\",\"name\":\"Help with this page\"}]",
        "hasstarterdata": true,
        "starters": [
            {
                "key": "help-page",
                "type": "prompt",
                "prompt": "Help me understand this page.",
                "builtin": true,
                "description": "Review the current page.",
                "icon_svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" width=\"16\" height=\"16\" fill=\"currentColor\"><path d=\"M12 2 2 7l10 5 10-5-10-5Zm0 7L2 4v13l10 5 10-5V4l-10 5Z\"/></svg>",
                "name": "Help with this page"
            }
        ]
    }
}}
<div id="local-ai-course-assistant"
     class="local-ai-course-assistant local-ai-course-assistant--{{positionclass}}{{#drawermode}} local-ai-course-assistant--drawer-mode{{/drawermode}}"
     style="--aica-starter-icon-color: {{startericoncolor}}{{^startericoncolor}}#023e8a{{/startericoncolor}};"
     data-courseid="{{courseid}}"
     data-userid="{{userid}}"
     data-sesskey="{{sesskey}}"
     data-userrole="{{userrole}}"
     data-sseurl="{{sseurl}}"
     data-avatarurl="{{avatarurl}}"
     data-availableavatars="{{availableavatars}}"
     data-quiz-topics="{{quiztopics}}"
     data-learning-objectives="{{learningobjectives}}"
     data-module-titles="{{moduletitles}}"
     data-offset-x="{{offsetx}}"
     data-offset-y="{{offsety}}"
     data-firstname="{{firstname}}"
     data-current-page-id="{{currentpageid}}"
     data-current-page-title="{{currentpagetitle}}"
     data-modname="{{modname}}"
     data-pagetype="{{pagetype}}"
     data-quiz-locked="{{#quizlocked}}1{{/quizlocked}}"
     data-realtimeenabled="{{realtimeenabled}}"
     data-talkingavatarenabled="{{#talkingavatarenabled}}1{{/talkingavatarenabled}}"
     data-ttsurl="{{ttsurl}}"
     data-avatar-color="{{avatarcolor}}"
     data-avatar-fill="{{avatarfill}}"
     data-settingsurl="{{coursesettingsurl}}"
     data-analyticsurl="{{analyticsurl}}"
     data-cansiteconfig="{{#cansiteconfig}}1{{/cansiteconfig}}"
     data-canviewanalytics="{{#canviewanalytics}}1{{/canviewanalytics}}"
     data-displaymode="{{displaymode}}"
     data-autoopen="{{#autoopen}}1{{/autoopen}}"
     data-displayname="{{displayname}}"
     data-shortname="{{shortname_label}}"
     data-institution="{{institution}}"
     data-practice-scoring="{{#practicescoring}}1{{/practicescoring}}"
     data-welcome-message="{{welcomemessage}}"
     data-chat-greeting="{{chatgreeting}}"
     data-coursename="{{coursename}}"
     data-intro-dismissed="{{#introdismissed}}1{{/introdismissed}}"
     data-digest-optin-state="{{digestoptinstate}}"
     data-emailreminders="{{#emailreminders}}1{{/emailreminders}}"
     data-whatsappreminders="{{#whatsappreminders}}1{{/whatsappreminders}}"
     data-useremail="{{useremail}}"
     data-userphone="{{userphone}}"
     data-surveyenabled="{{surveyenabled}}"
     data-surveytrigger="{{surveytrigger}}"
     data-completionpct="{{completionpct}}"
     data-defaultvoice="{{defaultvoice}}"
     data-context-debug="{{#contextdebugvisible}}1{{/contextdebugvisible}}"
     data-context-level="{{contextlevelname}}"
     data-server-page-url="{{serverpageurl}}"
     data-server-page-title="{{serverpagetitle}}"
     data-server-page-heading="{{serverpageheading}}"
     data-llm-options="{{llmoptionsjson}}"
     data-english-lock="{{#englishlock}}1{{/englishlock}}">

    {{! Floating avatar button }}
    <button id="local-ai-course-assistant-toggle"
            class="local-ai-course-assistant__toggle"
            type="button"
            aria-expanded="false"
            aria-controls="local-ai-course-assistant-drawer"
            title="{{#str}}chat:open, local_ai_course_assistant{{/str}}"
            aria-label="{{#str}}chat:open, local_ai_course_assistant{{/str}}">
        <span class="aica-avatar-svg aica-avatar-svg--toggle" aria-hidden="true"
              data-fallback-avatar="{{avatarurl}}">
            <img src="{{avatarurl}}" alt="" class="local-ai-course-assistant__avatar-img" aria-hidden="true" />
        </span>
    </button>

    {{! Chat drawer }}
    <div id="local-ai-course-assistant-drawer"
         class="local-ai-course-assistant__drawer"
         role="dialog"
         aria-label="{{shortname_label}}"
         aria-hidden="true"
         hidden>
        {{#studentmode}}
        {{! Subtle 2px indicator that student mode is active. Observers won't notice;
            admin knows to look for the thin bar. Ctrl+Shift+A exits. }}
        <div style="height:2px;background:linear-gradient(90deg,#ffc107,#fd7e14);flex-shrink:0" title="Student mode active (Ctrl+Shift+A to exit)"></div>
        {{/studentmode}}
        <button id="local-ai-course-assistant-close-toggle"
                class="local-ai-course-assistant__toggle local-ai-course-assistant__toggle--close"
                type="button"
                aria-expanded="false"
                aria-controls="local-ai-course-assistant-drawer"
                title="{{#str}}chat:close, local_ai_course_assistant{{/str}}"
                aria-label="{{#str}}chat:close, local_ai_course_assistant{{/str}}"
                hidden>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
            </svg>
        </button>

        {{! Swipe handle — mobile only; drag down to close }}
        <div class="aica-swipe-handle" aria-hidden="true"></div>

        {{! Header }}
        <div class="local-ai-course-assistant__header">
            <div class="local-ai-course-assistant__header-title">
                <button class="local-ai-course-assistant__btn-avatar"
                        title="{{#str}}chat:change_avatar, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:change_avatar, local_ai_course_assistant{{/str}}"
                        type="button">
                    <span class="aica-avatar-svg aica-avatar-svg--header" aria-hidden="true"
                          data-fallback-avatar="{{avatarurl}}">
                        <img src="{{avatarurl}}" alt="" class="local-ai-course-assistant__header-avatar" aria-hidden="true" />
                    </span>
                </button>
                <span>{{shortname_label}}</span>
            </div>
            <div class="local-ai-course-assistant__header-actions">
                {{#talkingavatarenabled}}
                <button class="local-ai-course-assistant__btn-talking-avatar"
                        title="{{#str}}talking_avatar:open, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}talking_avatar:open, local_ai_course_assistant{{/str}}"
                        aria-pressed="false"
                        type="button">
                    {{! Person icon — talking avatar }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16"
                         fill="currentColor" aria-hidden="true">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>
                </button>
                {{/talkingavatarenabled}}
                {{#canviewanalytics}}
                <a href="{{analyticsurl}}"
                   class="local-ai-course-assistant__btn-analytics"
                   title="{{#str}}analytics:viewdashboard, local_ai_course_assistant{{/str}}"
                   aria-label="{{#str}}analytics:viewdashboard, local_ai_course_assistant{{/str}}"
                   target="_blank">
                    {{#pix}}i/stats, core, {{#str}}analytics:viewdashboard, local_ai_course_assistant{{/str}}{{/pix}}
                </a>
                {{/canviewanalytics}}
                {{#cansiteconfig}}
                <a href="{{coursesettingsurl}}"
                   class="local-ai-course-assistant__btn-settings"
                   title="{{#str}}chat:settings, local_ai_course_assistant{{/str}}"
                   aria-label="{{#str}}chat:settings, local_ai_course_assistant{{/str}}"
                   target="_blank">
                    {{! Wrench icon — admin/course settings }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>
                    </svg>
                </a>
                {{/cansiteconfig}}
                <button class="local-ai-course-assistant__btn-settings-panel"
                        title="{{#str}}chat:settings_panel, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:settings_panel, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{! Gear / settings icon }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16"
                         fill="currentColor" aria-hidden="true">
                        <path d="M19.14 12.94c.04-.3.06-.61.06-.94s-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.49.49 0 0 0-.59-.22l-2.39.96a7.02 7.02 0 0 0-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.48.48 0 0 0-.59.22L2.74 8.87a.47.47 0 0 0 .12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.37 1.04.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.57 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32a.47.47 0 0 0-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                    </svg>
                </button>
                {{#contextdebugvisible}}
                <button class="local-ai-course-assistant__btn-debug"
                        title="{{#str}}chat:debug_context_toggle, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:debug_context_toggle, local_ai_course_assistant{{/str}}"
                        aria-pressed="false"
                        type="button">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16"
                         fill="currentColor" aria-hidden="true">
                        <path d="M20 8h-2.81a5.985 5.985 0 0 0-1.82-1.96L17 4.41 15.59 3l-2.17 2.17C12.96 5.06 12.49 5 12 5s-.96.06-1.41.17L8.41 3 7 4.41l1.62 1.63C7.88 6.55 7.26 7.22 6.81 8H4v2h2.09c-.05.33-.09.66-.09 1v1H4v2h2v1c0 .34.04.67.09 1H4v2h2.81c1.04 1.79 2.97 3 5.19 3s4.15-1.21 5.19-3H20v-2h-2.09c.05-.33.09-.66.09-1v-1h2v-2h-2v-1c0-.34-.04-.67-.09-1H20V8zm-6 8h-4v-2h4v2zm0-4h-4v-2h4v2z"/>
                    </svg>
                </button>
                {{/contextdebugvisible}}
                <button class="local-ai-course-assistant__btn-help"
                        title="Help"
                        aria-label="Help guide"
                        type="button">
                    {{! Question mark / help icon }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>
                    </svg>
                </button>
                <button class="local-ai-course-assistant__btn-clear"
                        title="{{#str}}chat:clear, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:clear, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{! Eraser icon — clear conversation history }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M15.14 3c-.51 0-1.02.2-1.41.59L2.59 14.73c-.78.77-.78 2.04 0 2.83l2.83 2.83c.39.39.9.59 1.41.59h4.24c.51 0 1.02-.2 1.41-.59l8.49-8.49c.78-.78.78-2.05 0-2.83l-4.24-4.24c-.39-.39-.9-.59-1.41-.59h.02zM6.83 19L4 16.17l5.93-5.93 2.83 2.83L6.83 19zM20 21H3v-2h17v2z"/>
                    </svg>
                </button>
                <button class="local-ai-course-assistant__btn-reset"
                        title="{{#str}}chat:reset, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:reset, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{! Home icon — return to conversation starters }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                    </svg>
                </button>
                <button class="local-ai-course-assistant__btn-close"
                        title="{{#str}}chat:close, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:close, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{! Close: standard X }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                    </svg>
                </button>
            </div>
        </div>

        {{! Focus sentinel — receives focus when drawer opens, prevents mobile keyboard pop-up }}
    <span class="aica-focus-sentinel" tabindex="-1" aria-hidden="true"></span>

    {{! First-run consent banner (GDPR Article 13, FERPA). Shown once per learner
        until `aica_sola_consent_given` user preference is set. }}
    {{^consentgiven}}
    <div class="aica-consent-banner" data-consent-url="{{consenturl}}" data-sesskey="{{sesskey}}"
         style="position:absolute;inset:0;z-index:20;background:rgba(255,255,255,0.98);
                display:flex;flex-direction:column;justify-content:center;padding:28px 24px;
                overflow-y:auto;font-size:14px;line-height:1.55">
        <h3 style="margin:0 0 12px;font-size:17px">{{consent_heading}}</h3>
        <p style="margin:0 0 14px;color:#333">{{consent_body}}</p>
        <p style="margin:0 0 18px;font-size:13px">
            <a href="{{privacynoticeurl}}" target="_blank" rel="noopener" style="color:#023e8a">
                {{#str}}chat:consent_privacy_link, local_ai_course_assistant{{/str}}
            </a>
        </p>
        <div>
            <button type="button" class="aica-consent-accept btn btn-primary"
                    style="padding:8px 16px;font-weight:600">
                {{consent_accept}}
            </button>
        </div>
    </div>
    <script>
    (function() {
        var banner = document.querySelector('.aica-consent-banner');
        if (!banner) { return; }
        var btn = banner.querySelector('.aica-consent-accept');
        if (!btn) { return; }
        btn.addEventListener('click', function() {
            var url = banner.dataset.consentUrl;
            var sk = banner.dataset.sesskey;
            var body = new URLSearchParams();
            body.append('sesskey', sk);
            fetch(url, {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: body.toString(),
                credentials: 'same-origin'
            }).finally(function() {
                banner.style.display = 'none';
            });
        });
    })();
    </script>
    {{/consentgiven}}

    {{! Help guide panel — toggled by the ? button in the header }}
    <div class="aica-help-panel" hidden style="position:absolute;inset:0;z-index:10;background:#fff;overflow-y:auto;padding:16px 20px;font-size:14px;line-height:1.6">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
            <h4 style="margin:0;font-size:16px">How to use {{shortname_label}}</h4>
            <button class="aica-help-panel__close" type="button" style="background:none;border:none;cursor:pointer;font-size:20px;padding:4px" aria-label="Close help">&times;</button>
        </div>
        <p><strong>{{displayname}}</strong> is your AI learning assistant for this course. It reads the course content and helps you study, practice, and understand the material.</p>
        <h5 style="margin:14px 0 6px;font-size:14px">Getting started</h5>
        <p>Click any conversation starter to begin, or type your own question. {{shortname_label}} answers based on the page you are on.</p>
        <h5 style="margin:14px 0 6px;font-size:14px">Practice quizzes</h5>
        <p>Click <strong>Quiz Me</strong> to get multiple-choice questions from the course content. You will see explanations after each answer and a score summary at the end.</p>
        <h5 style="margin:14px 0 6px;font-size:14px">Study plans</h5>
        <p>Click <strong>Study Plan</strong> to create a personalised week-by-week plan. Tell {{shortname_label}} your goal, how many hours you can study, and your deadline. You can opt into email reminders.</p>
        {{#voiceenabled}}
        <h5 style="margin:14px 0 6px;font-size:14px">Voice</h5>
        <p>
            Use the mic icon to speak your question.{{#voicetabenabled}} You can also switch to the Voice tab for a live two-way conversation.{{/voicetabenabled}}
        </p>
        {{/voiceenabled}}
        <h5 style="margin:14px 0 6px;font-size:14px">Languages</h5>
        <p>Click the gear icon and change the language. {{shortname_label}} supports 46 languages. All labels and responses switch instantly.</p>
        <h5 style="margin:14px 0 6px;font-size:14px">Your data</h5>
        <p>Your conversations are private to you and the institution. Click the eraser icon to permanently delete your conversation for this course. No one needs to approve it.</p>
    </div>

    {{! Language banner — shown by JS when browser language is detected }}
        <div class="local-ai-course-assistant__lang-banner" aria-hidden="true">
            <span class="local-ai-course-assistant__lang-banner-text"></span>
            <div class="local-ai-course-assistant__lang-banner-actions">
                <button class="local-ai-course-assistant__lang-accept"
                        aria-label="{{#str}}chat:language_switch, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{#str}}lang:switch, local_ai_course_assistant{{/str}}
                </button>
                <button class="local-ai-course-assistant__lang-dismiss"
                        aria-label="{{#str}}chat:language_dismiss, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{#str}}lang:dismiss, local_ai_course_assistant{{/str}}
                </button>
            </div>
        </div>

        {{#masterychipenabled}}
        {{! Learning Mastery Chip — compact pill, hydrated on drawer open. }}
        <div class="aica-mastery-chip-wrap">
            <button type="button" class="aica-mastery-chip" hidden
                    aria-expanded="false"
                    aria-label="{{#str}}mastery:chip_aria, local_ai_course_assistant{{/str}}">
                <span class="aica-mastery-chip__dot" aria-hidden="true"></span>
                <span class="aica-mastery-chip__label"></span>
            </button>
            <div class="aica-mastery-chip-popover" hidden role="dialog"
                 aria-label="{{#str}}mastery:popover_aria, local_ai_course_assistant{{/str}}">
                <div class="aica-mastery-chip-popover__body"></div>
            </div>
        </div>
        {{/masterychipenabled}}

        {{! Messages area }}
        <div class="local-ai-course-assistant__messages"
             role="log"
             aria-live="polite"
             aria-label="{{shortname_label}}">
        </div>

        {{#contextdebugvisible}}
        <div class="aica-debug-panel" hidden>
            <div class="aica-debug-panel__header">
                <span class="aica-debug-panel__title">{{#str}}chat:debug_context, local_ai_course_assistant{{/str}}</span>
                <button type="button"
                        class="aica-debug-panel__copy"
                        aria-label="{{#str}}chat:debug_context_copy, local_ai_course_assistant{{/str}}">
                    {{#str}}chat:debug_context_copy, local_ai_course_assistant{{/str}}
                </button>
            </div>
            <div class="aica-debug-panel__content">
