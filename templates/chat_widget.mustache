{{!
    @template local_ai_course_assistant/chat_widget

    Chat widget with floating avatar button and slide-in drawer.

    Context variables required for this template:
    * courseid - The course ID
    * sesskey - Session key for CSRF protection
    * avatarurl - URL to the avatar SVG
    * positionclass - CSS position class (bottom-right or bottom-left)
    * userrole - User role (student or teacher)
    * sseurl - URL for the SSE streaming endpoint
}}
<div id="local-ai-course-assistant"
     class="local-ai-course-assistant local-ai-course-assistant--{{positionclass}}"
     data-courseid="{{courseid}}"
     data-sesskey="{{sesskey}}"
     data-userrole="{{userrole}}"
     data-sseurl="{{sseurl}}"
     data-avatarurl="{{avatarurl}}"
     data-availableavatars="{{availableavatars}}"
     data-quiz-topics="{{quiztopics}}"
     data-learning-objectives="{{learningobjectives}}"
     data-module-titles="{{moduletitles}}"
     data-offset-x="{{offsetx}}"
     data-offset-y="{{offsety}}"
     data-firstname="{{firstname}}"
     data-current-page-id="{{currentpageid}}"
     data-current-page-title="{{currentpagetitle}}"
     data-modname="{{modname}}"
     data-pagetype="{{pagetype}}"
     data-quiz-locked="{{#quizlocked}}1{{/quizlocked}}"
     data-realtimeenabled="{{realtimeenabled}}"
     data-ttsurl="{{ttsurl}}"
     data-avatar-color="{{avatarcolor}}"
     data-avatar-fill="{{avatarfill}}"
     data-settingsurl="{{coursesettingsurl}}"
     data-analyticsurl="{{analyticsurl}}"
     data-cansiteconfig="{{#cansiteconfig}}1{{/cansiteconfig}}"
     data-canviewanalytics="{{#canviewanalytics}}1{{/canviewanalytics}}">

    {{! Floating avatar button }}
    <button id="local-ai-course-assistant-toggle"
            class="local-ai-course-assistant__toggle"
            aria-expanded="false"
            aria-controls="local-ai-course-assistant-drawer"
            title="{{#str}}chat:open, local_ai_course_assistant{{/str}}">
        <div class="aica-avatar-svg aica-avatar-svg--toggle" aria-hidden="true"
             data-fallback-avatar="{{avatarurl}}">
            <img src="{{avatarurl}}" alt="" class="local-ai-course-assistant__avatar-img" aria-hidden="true" />
        </div>
    </button>

    {{! Chat drawer }}
    <div id="local-ai-course-assistant-drawer"
         class="local-ai-course-assistant__drawer"
         role="dialog"
         aria-label="{{#str}}chat:title, local_ai_course_assistant{{/str}}"
         aria-hidden="true">

        {{! Swipe handle — mobile only; drag down to close }}
        <div class="aica-swipe-handle" aria-hidden="true"></div>

        {{! Header }}
        <div class="local-ai-course-assistant__header">
            <div class="local-ai-course-assistant__header-title">
                <button class="local-ai-course-assistant__btn-avatar"
                        title="{{#str}}chat:change_avatar, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:change_avatar, local_ai_course_assistant{{/str}}"
                        type="button">
                    <div class="aica-avatar-svg aica-avatar-svg--header" aria-hidden="true"
                         data-fallback-avatar="{{avatarurl}}">
                        <img src="{{avatarurl}}" alt="" class="local-ai-course-assistant__header-avatar" aria-hidden="true" />
                    </div>
                </button>
                <span>{{#str}}chat:title, local_ai_course_assistant{{/str}}</span>
            </div>
            <div class="local-ai-course-assistant__header-actions">
                {{#ttsurl}}
                <button class="local-ai-course-assistant__btn-voice"
                        title="{{#str}}chat:voice_mode, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:voice_mode, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{! Headphone icon — voice conversation mode }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M12 1a9 9 0 0 0-9 9v4a3 3 0 0 0 3 3h1a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H6v-1a6 6 0 0 1 12 0v1h-1a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h1a3 3 0 0 0 3-3v-4a9 9 0 0 0-9-9z"/>
                    </svg>
                </button>
                {{/ttsurl}}
                {{#canviewanalytics}}
                <a href="{{analyticsurl}}"
                   class="local-ai-course-assistant__btn-analytics"
                   title="{{#str}}analytics:viewdashboard, local_ai_course_assistant{{/str}}"
                   aria-label="{{#str}}analytics:viewdashboard, local_ai_course_assistant{{/str}}"
                   target="_blank">
                    {{#pix}}i/stats, core, {{#str}}analytics:viewdashboard, local_ai_course_assistant{{/str}}{{/pix}}
                </a>
                {{/canviewanalytics}}
                {{#cansiteconfig}}
                <a href="{{coursesettingsurl}}"
                   class="local-ai-course-assistant__btn-settings"
                   title="{{#str}}chat:settings, local_ai_course_assistant{{/str}}"
                   aria-label="{{#str}}chat:settings, local_ai_course_assistant{{/str}}"
                   target="_blank">
                    {{! Wrench icon — admin/course settings }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>
                    </svg>
                </a>
                {{/cansiteconfig}}
                <button class="local-ai-course-assistant__btn-settings-panel"
                        title="{{#str}}chat:settings_panel, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:settings_panel, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{! Gear / settings icon }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16"
                         fill="currentColor" aria-hidden="true">
                        <path d="M19.14 12.94c.04-.3.06-.61.06-.94s-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.49.49 0 0 0-.59-.22l-2.39.96a7.02 7.02 0 0 0-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.48.48 0 0 0-.59.22L2.74 8.87a.47.47 0 0 0 .12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.37 1.04.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.57 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32a.47.47 0 0 0-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                    </svg>
                </button>
                <button class="local-ai-course-assistant__btn-clear"
                        title="{{#str}}chat:clear, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:clear, local_ai_course_assistant{{/str}}"
                        type="button">
                    {{! Trash icon — delete conversation history }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                    </svg>
                </button>
                <button class="local-ai-course-assistant__btn-reset"
                        title="{{#str}}chat:reset, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:reset, local_ai_course_assistant{{/str}}">
                    {{! Home icon — return to conversation starters }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                    </svg>
                </button>
                <button class="local-ai-course-assistant__btn-expand"
                        title="{{#str}}chat:expand, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:expand, local_ai_course_assistant{{/str}}">
                    {{! Expand: two arrows pointing away from each other (unfold) }}
                    <span class="aica-icon-expand" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
                            <path d="M12 5.83L15.17 9l1.41-1.41L12 3 7.41 7.59 8.83 9 12 5.83zm0 12.34L8.83 15l-1.41 1.41L12 21l4.59-4.59L15.17 15 12 18.17z"/>
                        </svg>
                    </span>
                    {{! Collapse: two arrows pointing toward each other (fold) }}
                    <span class="aica-icon-collapse" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
                            <path d="M7.41 18.59L8.83 20 12 16.83 15.17 20l1.41-1.41L12 14l-4.59 4.59zm9.18-13.18L15.17 4 12 7.17 8.83 4 7.41 5.41 12 10l4.59-4.59z"/>
                        </svg>
                    </span>
                </button>
                <button class="local-ai-course-assistant__btn-close"
                        title="{{#str}}chat:close, local_ai_course_assistant{{/str}}"
                        aria-label="{{#str}}chat:close, local_ai_course_assistant{{/str}}">
                    {{! Close: standard X }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                    </svg>
                </button>
            </div>
        </div>

        {{! Focus sentinel — receives focus when drawer opens, prevents mobile keyboard pop-up }}
    <span class="aica-focus-sentinel" tabindex="-1" aria-hidden="true"></span>

    {{! Language banner — shown by JS when browser language is detected }}
        <div class="local-ai-course-assistant__lang-banner" aria-hidden="true">
            <span class="local-ai-course-assistant__lang-banner-text"></span>
            <div class="local-ai-course-assistant__lang-banner-actions">
                <button class="local-ai-course-assistant__lang-accept">
                    {{#str}}lang:switch, local_ai_course_assistant{{/str}}
                </button>
                <button class="local-ai-course-assistant__lang-dismiss">
                    {{#str}}lang:dismiss, local_ai_course_assistant{{/str}}
                </button>
            </div>
        </div>

        {{! Messages area }}
        <div class="local-ai-course-assistant__messages"
             role="log"
             aria-live="polite"
             aria-label="{{#str}}chat:title, local_ai_course_assistant{{/str}}">
        </div>

        {{! Conversation starters — hidden once a message is sent }}
        <div class="local-ai-course-assistant__starters" aria-label="{{#str}}chat:starters_label, local_ai_course_assistant{{/str}}">
            <button class="local-ai-course-assistant__starter" data-starter="quiz">
                <span class="aica-starter-icon" aria-hidden="true">
                    {{! Lightning bolt — Quiz Me }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M7 2v11h3v9l7-12h-4l4-8z"/></svg>
                </span>
                <span>{{#str}}chat:starter_quiz, local_ai_course_assistant{{/str}}</span>
            </button>
            <button class="local-ai-course-assistant__starter" data-starter="explain">
                <span class="aica-starter-icon" aria-hidden="true">
                    {{! Lightbulb — Explain This }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z"/></svg>
                </span>
                <span>{{#str}}chat:starter_explain, local_ai_course_assistant{{/str}}</span>
            </button>
            <button class="local-ai-course-assistant__starter" data-starter="key-concepts">
                <span class="aica-starter-icon" aria-hidden="true">
                    {{! Star — Key Concepts }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                </span>
                <span>{{#str}}chat:starter_key_concepts, local_ai_course_assistant{{/str}}</span>
            </button>
            <button class="local-ai-course-assistant__starter" data-starter="study-plan">
                <span class="aica-starter-icon" aria-hidden="true">
                    {{! Calendar — Study Plan }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M20 3h-1V1h-2v2H7V1H5v2H4C2.9 5 2 5.9 2 7v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 18H4V10h16v11zm0-13H4V7h16v1z"/></svg>
                </span>
                <span>{{#str}}chat:starter_study_plan, local_ai_course_assistant{{/str}}</span>
            </button>
            {{#ttsurl}}
            <button class="local-ai-course-assistant__starter"
                    data-starter="ell-practice">
                <span class="aica-starter-icon" aria-hidden="true">
                    {{! Mic icon — Practice Speaking }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.93V21h2v-3.07A7 7 0 0 0 19 11h-2z"/>
                    </svg>
                </span>
                <span>{{#str}}chat:starter_ell_practice, local_ai_course_assistant{{/str}}</span>
            </button>
            {{/ttsurl}}
            {{#ellpronunciationenabled}}
            <button class="local-ai-course-assistant__starter"
                    data-starter="ell-pronunciation">
                <span class="aica-starter-icon" aria-hidden="true">
                    {{! Sound waves icon — ELL Pronunciation }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0 0 14 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
                    </svg>
                </span>
                <span>{{#str}}chat:starter_ell_pronunciation, local_ai_course_assistant{{/str}}</span>
            </button>
            {{/ellpronunciationenabled}}
            <button class="local-ai-course-assistant__starter" data-starter="ai-coach">
                <span class="aica-starter-icon" aria-hidden="true">
                    {{! Robot/AI icon — AI Coach }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7H4a7 7 0 0 1 7-7h1V5.73A2 2 0 0 1 10 4a2 2 0 0 1 2-2M4 15h16v1a7 7 0 0 1-7 7H11a7 7 0 0 1-7-7v-1m3 2v1a4 4 0 0 0 4 4h2a4 4 0 0 0 4-4v-1H7z"/></svg>
                </span>
                <span>{{#str}}chat:starter_ai_coach, local_ai_course_assistant{{/str}}</span>
            </button>
            <button class="local-ai-course-assistant__starter" data-starter="quick-study">
                <span class="aica-starter-icon" aria-hidden="true">
                    {{! Timer icon — Quick Study }}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M15 1H9v2h6V1zm-4 13h2V8h-2v6zm8.03-6.61 1.42-1.42c-.43-.51-.9-.99-1.41-1.41l-1.42 1.42A7.73 7.73 0 0 0 12 4a8 8 0 1 0 8 8c0-2.21-.9-4.21-2.03-5.39zm-1.97 9.61A6 6 0 1 1 12 6a6 6 0 0 1 5.06 9.61z"/></svg>
                </span>
                <span>{{#str}}chat:starter_quick_study, local_ai_course_assistant{{/str}}</span>
            </button>
        </div>

        {{! Typing indicator }}
        <div class="local-ai-course-assistant__typing" aria-hidden="true">
            <span class="local-ai-course-assistant__typing-dot"></span>
            <span class="local-ai-course-assistant__typing-dot"></span>
            <span class="local-ai-course-assistant__typing-dot"></span>
        </div>

        {{! Input area }}
        <div class="local-ai-course-assistant__input-area">
            <textarea class="local-ai-course-assistant__input"
                      placeholder="{{#str}}chat:placeholder, local_ai_course_assistant{{/str}}"
                      rows="1"
                      aria-label="{{#str}}chat:placeholder, local_ai_course_assistant{{/str}}"></textarea>
            <button class="local-ai-course-assistant__btn-mic"
                    title="{{#str}}chat:mic, local_ai_course_assistant{{/str}}"
                    aria-label="{{#str}}chat:mic, local_ai_course_assistant{{/str}}"
                    type="button">
                {{! Mic icon — inline SVG for reliability across Moodle versions }}
                <svg class="aica-icon-mic" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                    <path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.93V21h2v-3.07A7 7 0 0 0 19 11h-2z"/>
                </svg>
                <svg class="aica-icon-mic-stop" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                    <path d="M19 11h-2a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.93V21h2v-3.07A7 7 0 0 0 19 11zM9 5a3 3 0 0 1 6 0v6a3 3 0 0 1-6 0V5z" opacity=".3"/>
                    <rect x="9" y="9" width="6" height="6" rx="1"/>
                </svg>
            </button>
            <button class="local-ai-course-assistant__btn-send"
                    title="{{#str}}chat:send, local_ai_course_assistant{{/str}}"
                    aria-label="{{#str}}chat:send, local_ai_course_assistant{{/str}}"
                    disabled>
                {{#pix}}t/go, core, {{#str}}chat:send, local_ai_course_assistant{{/str}}{{/pix}}
            </button>
        </div>
        {{! Resize handles — drag top/left edges to resize the drawer }}
        <div class="aica-resize-handle aica-resize-handle--n" aria-hidden="true"></div>
        <div class="aica-resize-handle aica-resize-handle--w" aria-hidden="true"></div>
        <div class="aica-resize-handle aica-resize-handle--nw" aria-hidden="true"></div>

        <div class="local-ai-course-assistant__hint">
            <span>{{#str}}chat:newline_hint, local_ai_course_assistant{{/str}}</span>
            <button type="button"
                    class="local-ai-course-assistant__btn-lang"
                    aria-label="Change language">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                     width="11" height="11" fill="currentColor" aria-hidden="true"
                     style="vertical-align:-1px;margin-right:3px">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                </svg><span class="aica-lang-label">English</span>
            </button>
        </div>
    </div>
</div>
